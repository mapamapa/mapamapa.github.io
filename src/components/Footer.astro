---
const links = [
  { href: '/', label: 'Home' },
  { href: '/us/', label: 'Us' },
  { href: '/work/', label: 'Work' },
  { href: '/social/', label: 'Social' },
  { href: '/contact/', label: 'Contact' },
];
---

<footer class="footer">
  <div class="footer__inner container">
    <hr class="footer__line" />
    <div class="footer__row">
      <a href="/" class="footer__logo" aria-label="MAPA MAPA — Inicio">
        <img src="/img/logo.png" alt="MAPA MAPA" class="footer__logo-img" width="80" height="auto" loading="lazy" decoding="async" />
      </a>
      <nav class="footer__nav" aria-label="Navegación footer">
        <ul class="footer__links">
          {links.map(({ href, label }) => (
            <li><a href={href} class="footer__link">{label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-xl) 0 var(--space-lg);
    margin-top: var(--space-3xl);
  }

  .footer__inner {
    max-width: 1100px;
  }

  .footer__line {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-bottom: var(--space-xl);
  }

  .footer__row {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    max-width: 900px;
    margin-inline: auto;
  }

  .footer__logo {
    flex-shrink: 0;
    margin-right: auto;
  }

  .footer__logo-img {
    width: 80px;
    height: auto;
    filter: brightness(0) invert(0.75);
    transition: filter var(--duration-fast);
  }

  .footer__logo:hover .footer__logo-img {
    filter: brightness(0) invert(1);
  }

  .footer__nav {
    flex-shrink: 0;
  }

  .footer__links {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .footer__link {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    transition: color var(--duration-fast);
  }

  .footer__link:hover {
    color: var(--color-hover);
  }

  @media (max-width: 768px) {
    .footer__row {
      flex-direction: column;
      align-items: center;
      gap: var(--space-md);
    }

    .footer__links {
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-md);
    }
  }
</style>
