---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/us/', label: 'Us' },
  { href: '/work/', label: 'Work' },
  { href: '/social/', label: 'Social' },
  { href: '/contact/', label: 'Contact' },
];
---

<header class="nav" id="nav">
  <nav class="nav__inner" aria-label="Navegación principal">
    <ul class="nav__list" id="nav-list">
      {links.map(({ href, label }) => (
        <li class="nav__item">
          <a
            href={href}
            class:list={['nav__link', { 'nav__link--active': currentPath === href }]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  let scrollHandler: (() => void) | null = null;

  function initNav() {
    const nav = document.getElementById('nav');
    if (!nav) return;

    nav.classList.remove('nav--scrolled', 'nav--hidden');

    if (scrollHandler) {
      window.removeEventListener('scroll', scrollHandler);
    }

    let lastScroll = 0;
    scrollHandler = () => {
      const y = window.scrollY;
      nav.classList.toggle('nav--scrolled', y > 60);
      nav.classList.toggle('nav--hidden', y > 400 && y > lastScroll);
      lastScroll = y;
    };
    window.addEventListener('scroll', scrollHandler, { passive: true });
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: var(--z-nav);
    padding: var(--space-sm) var(--gutter);
    transition: background-color var(--duration-normal) var(--ease-out-expo),
                transform var(--duration-normal) var(--ease-out-expo);
  }

  .nav--scrolled {
    background-color: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav--hidden {
    transform: translateY(-100%);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 900px;
    margin-inline: auto;
  }

  .nav__list {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: var(--space-sm);
  }

  .nav__link {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.4em 0;
    white-space: nowrap;
    transition: opacity var(--duration-fast);
  }

  .nav__link:hover {
    color: #df9de5;
  }

  .nav__link--active {
    opacity: 0.6;
  }

  @media (min-width: 768px) {
    .nav__link {
      font-size: var(--text-lg);
    }
  }
</style>
