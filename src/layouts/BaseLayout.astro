---
import { ViewTransitions } from 'astro:transitions';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'MAPA MAPA',
  description = 'Gestión y producción cultural. Nos mueven las historias que conectan y las experiencias que transforman.',
  image = '/img/logo.png',
} = Astro.props;

const pageTitle = title === 'MAPA MAPA' ? title : `${title} — MAPA MAPA`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://mapamapa.cl');
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MAPA MAPA" />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Fonts: preconnect + preload for fast render -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet" />
    </noscript>

    <title>{pageTitle}</title>
    <ViewTransitions />
  </head>
  <body>
    <div class="preloader" id="preloader">
      <img src="/img/logo.png" alt="MAPA MAPA" width="80" height="80" style="opacity:0.6" />
    </div>

    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      import { gsap, ScrollTrigger } from '@/scripts/gsap';

      const DELAY_STEP = 0.1;

      function dismissPreloader() {
        const loader = document.getElementById('preloader');
        if (!loader || loader.dataset.done) return;
        loader.dataset.done = '1';
        gsap.to(loader, {
          opacity: 0,
          duration: 0.4,
          ease: 'power2.out',
          onComplete: () => loader.remove(),
        });
      }

      const REVEAL_ST_ID = 'reveal';

      function killRevealTriggers() {
        ScrollTrigger.getAll()
          .filter((t) => (t.vars as any).id === REVEAL_ST_ID)
          .forEach((t) => t.kill());
      }

      function initRevealAnimations() {
        killRevealTriggers();

        const reveals = document.querySelectorAll<HTMLElement>('.reveal');
        if (!reveals.length) {
          dismissPreloader();
          return;
        }

        const isMobile = window.matchMedia('(max-width: 768px)').matches;
        const yOffset = isMobile ? 12 : 30;

        gsap.set(reveals, { autoAlpha: 0, y: yOffset });

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          gsap.set(reveals, { autoAlpha: 1, y: 0 });
          dismissPreloader();
          return;
        }

        reveals.forEach((el) => {
          const delayClass = Array.from(el.classList).find((c) => c.startsWith('reveal-delay-'));
          const delay = delayClass ? parseInt(delayClass.replace('reveal-delay-', ''), 10) * DELAY_STEP : 0;

          gsap.to(el, {
            autoAlpha: 1,
            y: 0,
            duration: 0.8,
            delay,
            ease: 'expo.out',
            scrollTrigger: {
              id: REVEAL_ST_ID,
              trigger: el,
              start: 'top bottom-=30px',
              once: true,
            },
          });
        });

        dismissPreloader();
      }

      function onReady() {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => initRevealAnimations());
        });
      }

      if (document.readyState === 'complete') {
        onReady();
      } else {
        window.addEventListener('load', onReady);
      }

      document.addEventListener('astro:after-swap', () => {
        requestAnimationFrame(() => initRevealAnimations());
      });
    </script>
  </body>
</html>
