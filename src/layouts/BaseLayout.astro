---
import { ViewTransitions } from 'astro:transitions';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'MAPA MAPA',
  description = 'Gestión y producción cultural. Nos mueven las historias que conectan y las experiencias que transforman.',
  image = '/img/logo.png',
} = Astro.props;

const pageTitle = title === 'MAPA MAPA' ? title : `${title} — MAPA MAPA`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://mapamapa.cl');
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MAPA MAPA" />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Fonts: preconnect + preload for fast render -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;900&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;900&display=swap" rel="stylesheet" />
    </noscript>

    <title>{pageTitle}</title>
    <ViewTransitions />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      let revealObserver: IntersectionObserver | null = null;

      function initRevealAnimations(immediate = false) {
        if (revealObserver) {
          revealObserver.disconnect();
          revealObserver = null;
        }

        const reveals = document.querySelectorAll('.reveal');
        reveals.forEach((el) => el.classList.remove('visible'));

        if (!reveals.length) return;

        if (immediate) {
          const vh = window.innerHeight;
          reveals.forEach((el) => {
            if (el.getBoundingClientRect().top < vh + 40) {
              el.classList.add('visible');
            }
          });
        }

        revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                revealObserver?.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
        );

        reveals.forEach((el) => {
          if (!el.classList.contains('visible')) {
            revealObserver!.observe(el);
          }
        });
      }

      initRevealAnimations(false);

      document.addEventListener('astro:after-swap', () => {
        requestAnimationFrame(() => initRevealAnimations(true));
      });
    </script>
  </body>
</html>
