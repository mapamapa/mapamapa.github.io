---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Artel — Museografía Aniversario 85 años';
const description = 'Propuesta museográfica para la exposición conmemorativa del 85° aniversario de Artel en el MAVI.';

const gallery = {
  expo1: '/img/artel/expo1.jpg',
  expo2: '/img/artel/expo2.jpg',
  expo3: '/img/artel/expo3.jpg',
  expo4: '/img/artel/expo4.jpg',
  expo5: '/img/artel/expo5.jpg',
  expo6: '/img/artel/expo6.jpg',
  expo7: '/img/artel/expo7.jpg',
  expo8: '/img/artel/expo8.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.expo7}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.expo7}
          alt="Vista general de la exposición Artel 85 años en MAVI"
          width="847"
          height="347"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>Artel | Museografía</h1>
        <p class="production__subtitle">Aniversario 85 años — MAVI</p>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="artel-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="artel-copy-title" class="sr-only">Descripción del proyecto</h2>
        <p>
          Con motivo del 85° aniversario de una de las marcas nacionales más icónicas, se desarrolló la propuesta de una exposición conmemorativa que celebrara su trayectoria y relevancia cultural.
        </p>
        <p>
          El proyecto consistió en la creación de una exposición que integró y organizó visualmente las diferentes líneas de productos que la compañía ha lanzado a lo largo de su historia.
        </p>
        <p>
          El objetivo principal fue destacar aquellos productos que han acompañado a generaciones.
        </p>
      </div>

      <figure class="production__card production__card--q1 reveal reveal-delay-2">
        <img
          src={gallery.expo2}
          alt="Productos Artel exhibidos en la muestra"
          width="345"
          height="297"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q2 reveal reveal-delay-2">
        <img
          src={gallery.expo1}
          alt="Detalle de vitrinas con productos históricos"
          width="345"
          height="297"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q3 reveal reveal-delay-3">
        <img
          src={gallery.expo3}
          alt="Diseño museográfico de la exposición"
          width="296"
          height="260"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q4 reveal reveal-delay-3">
        <img
          src={gallery.expo5}
          alt="Organización visual de líneas de productos"
          width="413"
          height="295"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q5 reveal reveal-delay-3">
        <img
          src={gallery.expo4}
          alt="Espacio de la exposición en MAVI"
          width="410"
          height="295"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q6 reveal reveal-delay-4">
        <img
          src={gallery.expo6}
          alt="Elementos históricos de Artel en exhibición"
          width="296"
          height="260"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q7 reveal reveal-delay-4">
        <img
          src={gallery.expo8}
          alt="Detalle de montaje museográfico"
          width="296"
          height="260"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(5.5rem, 8vw, 7rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
  }

  .production__hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__subtitle {
    font-size: clamp(1rem, 0.8rem + 1.2vw, 1.5rem);
    color: #999;
    line-height: 1.1;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__copy {
    grid-column: span 5;
    display: grid;
    gap: 1rem;
    padding-right: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__card--q1 {
    grid-column: 6 / 9;
  }

  .production__card--q2 {
    grid-column: 9 / -1;
  }

  .production__card--q3 {
    grid-column: 1 / 4;
  }

  .production__card--q4 {
    grid-column: 4 / 8;
  }

  .production__card--q5 {
    grid-column: 8 / -1;
  }

  .production__card--q6 {
    grid-column: 1 / 4;
  }

  .production__card--q7 {
    grid-column: 4 / 7;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr 1fr;
      gap: 0;
    }

    .production__copy {
      grid-column: 1 / -1;
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }

    .production__card--q1,
    .production__card--q2,
    .production__card--q3,
    .production__card--q4,
    .production__card--q5,
    .production__card--q6,
    .production__card--q7 {
      grid-column: auto;
    }
  }
</style>
