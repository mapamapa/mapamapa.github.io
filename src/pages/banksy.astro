---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'The Art of Banksy Without Limits';
const description = 'Exposición que rindió homenaje al enigmático artista británico Banksy con originales certificados, grabados, esculturas e instalaciones.';

const gallery = {
  hero: '/img/banksy/cover.png',
  artwork: '/img/banksy/artwork.png',
  stencil: '/img/banksy/stencil.png',
  expo: '/img/banksy/expo1.jpg',
  panoramic: '/img/banksy/panoramic.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="hero-comp reveal">
      <img
        src={gallery.artwork}
        alt="Escultura de Banksy con rostro pixelado"
        class="hero-comp__bust"
        data-parallax="-0.15"
        width="540"
        height="700"
        fetchpriority="high"
        decoding="async"
      />
      <h1 class="hero-comp__title" aria-label="The Art of Banksy Without Limits">
        <span class="hero-comp__line" data-text="the-art" data-parallax="-0.35">The Art</span>
        <span class="hero-comp__line" data-text="of" data-parallax="-0.25">of</span>
        <span class="hero-comp__line" data-text="banksy" data-parallax="-0.45">Banksy</span>
      </h1>
      <p class="hero-comp__subtitle" data-parallax="-0.1">"Without Limits"</p>
    </header>

    <p class="production__intro reveal reveal-delay-2">
      Una exposición que rindió homenaje al enigmático artista británico Banksy, a través de una cuidada selección de originales certificados, grabados, fotografías, litografías, esculturas, murales, instalaciones de video y reproducciones de sus icónicos stencils, reconocidos mundialmente por su aguda mirada social.
    </p>

    <div class="production__images reveal reveal-delay-2">
      <img
        src={gallery.stencil}
        alt="Stencil icónico de Banksy en la muestra"
        width="728"
        height="407"
        loading="lazy"
        decoding="async"
      />
      <div class="production__images-right">
        <img
          src={gallery.expo}
          alt="Sala de la exposición Banksy con obras en exhibición"
          width="572"
          height="363"
          loading="lazy"
          decoding="async"
        />
        <p class="production__moved-copy">
          La muestra reunió una cuidada selección de originales certificados, grabados, fotografías, litografías, esculturas, murales, instalaciones de video y reproducciones de sus icónicos stencils.
        </p>
      </div>
    </div>

    <section class="production__editorial" aria-labelledby="banksy-copy-title">
      <div class="production__copy reveal reveal-delay-3">
        <h2 id="banksy-copy-title" class="sr-only">Descripción del proyecto</h2>
        <p>
          MAPAMAPA estuvo a cargo de la producción técnica asegurando el óptimo desarrollo de la muestra en aspectos de iluminación, sonido, montaje y soporte técnico, para que cada pieza y espacio transmitiera con precisión la fuerza estética y política del artista.
        </p>
      </div>

      <figure class="production__panoramic">
        <img
          src={gallery.panoramic}
          alt="Vista panorámica de la exposición Banksy"
          width="1600"
          height="400"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>

    <figure class="production__bottom-video reveal reveal-delay-3">
      <video
        loop
        muted
        playsinline
        preload="none"
        data-src="/img/BANKSY_ONLINE.mp4"
      />
    </figure>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(2.5rem, 4vw, 4rem);
    padding-bottom: var(--space-xl);
  }

  /* ---- Hero composition ---- */
  .hero-comp {
    position: relative;
    background: #000;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    margin-bottom: var(--space-lg);
  }

  .hero-comp__bust {
    position: absolute;
    bottom: 10%;
    left: 50%;
    height: 78%;
    width: auto;
    max-width: none;
    object-fit: contain;
    z-index: 2;
  }

  .hero-comp__title {
    position: absolute;
    inset: 0;
    margin: 0;
  }

  .hero-comp__line {
    position: absolute;
    color: #999;
    text-transform: uppercase;
    line-height: 0.9;
    letter-spacing: -0.02em;
    font-weight: 900;
  }

  [data-text='the-art'] {
    top: 15%;
    left: 5%;
    z-index: 1;
    font-size: clamp(2.2rem, 1.5rem + 3.5vw, 5.5rem);
  }

  [data-text='of'] {
    top: 41%;
    left: 35%;
    z-index: 1;
    font-size: clamp(1.8rem, 1.2rem + 2.8vw, 4.2rem);
  }

  [data-text='banksy'] {
    bottom: 22%;
    right: 8%;
    z-index: 3;
    font-size: clamp(2.6rem, 2rem + 4vw, 6.5rem);
  }

  .hero-comp__subtitle {
    position: absolute;
    bottom: 2%;
    left: 50%;
    z-index: 3;
    font-size: clamp(1rem, 0.8rem + 1.2vw, 1.8rem);
    color: #ccc;
    text-transform: none;
    font-weight: 400;
    white-space: nowrap;
  }

  @media (max-width: 599px) {
    .hero-comp {
      aspect-ratio: 3 / 4;
    }

    .hero-comp__bust {
      height: 58%;
      bottom: 14%;
    }

    [data-text='the-art'] {
      top: 26%;
      left: 4%;
      font-size: clamp(1.6rem, 1rem + 4vw, 2.5rem);
    }

    [data-text='of'] {
      top: 34%;
      left: 30%;
      font-size: clamp(1.3rem, 0.8rem + 3vw, 2rem);
    }

    [data-text='banksy'] {
      bottom: 18%;
      right: 4%;
      font-size: clamp(2rem, 1.2rem + 5vw, 3rem);
    }

    .hero-comp__subtitle {
      bottom: 4%;
    }
  }

  .production__intro {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    margin-bottom: var(--space-md);
  }

  .production__images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: var(--space-md);
  }

  .production__images > img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .production__images-right {
    display: flex;
    flex-direction: column;
  }

  .production__images-right img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    display: block;
  }

  .production__moved-copy {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    margin-top: var(--space-sm);
    margin-left: 15px;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__panoramic {
    grid-column: 1 / -1;
    margin-top: var(--space-md);
  }

  .production__panoramic img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }

  .production__bottom-video {
    width: 100%;
    margin-top: var(--space-md);
    overflow: hidden;
  }

  .production__bottom-video video {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .production__copy {
    grid-column: 1 / -1;
    display: grid;
    gap: 1rem;
    margin-bottom: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__card--side {
    grid-column: 7 / -1;
  }

  .production__card--left {
    grid-column: 1 / 7;
  }

  .production__card--right {
    grid-column: 7 / -1;
  }

  @media (min-width: 900px) {
    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .production__copy,
    .production__card--side,
    .production__card--left,
    .production__card--right {
      grid-column: auto;
    }

    .production__copy {
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }
  }

  .hero-comp [data-parallax] {
    will-change: transform;
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '@/scripts/gsap';

  function initParallax() {
    const hero = document.querySelector<HTMLElement>('.hero-comp');
    if (!hero) return;

    hero.querySelectorAll<HTMLElement>('.hero-comp__bust, .hero-comp__subtitle').forEach((el) => {
      gsap.set(el, { xPercent: -50 });
    });

    const els = hero.querySelectorAll<HTMLElement>('[data-parallax]');

    els.forEach((el) => {
      const speed = parseFloat(el.dataset.parallax ?? '0');

      gsap.fromTo(el, {
        y: () => -speed * hero.offsetHeight * 0.3,
      }, {
        y: () => speed * hero.offsetHeight * 0.7,
        ease: 'none',
        scrollTrigger: {
          trigger: hero,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 0.5,
        },
      });
    });
  }

  function lazyLoadVideos() {
    const videos = document.querySelectorAll<HTMLVideoElement>('video[data-src]');
    if (!videos.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const video = entry.target as HTMLVideoElement;
            video.src = video.dataset.src!;
            video.load();
            video.play();
            observer.unobserve(video);
          }
        });
      },
      { rootMargin: '200px' }
    );

    videos.forEach((video) => observer.observe(video));
  }

  document.addEventListener('astro:page-load', initParallax);
  document.addEventListener('astro:page-load', lazyLoadVideos);
</script>
