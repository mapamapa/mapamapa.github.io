---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'The Art of Banksy Without Limits';
const description = 'Exposición que rindió homenaje al enigmático artista británico Banksy con originales certificados, grabados, esculturas e instalaciones.';

const gallery = {
  hero: '/img/banksy/panoramic.jpg',
  artwork: '/img/banksy/artwork.png',
  stencil: '/img/banksy/stencil.png',
  expo: '/img/banksy/expo1.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.hero}
          alt="Vista panorámica de la exposición Banksy"
          width="1600"
          height="335"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>The Art of Banksy<br /><span class="production__sub">Without Limits</span></h1>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="banksy-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="banksy-copy-title" class="sr-only">Descripción del proyecto</h2>
        <p>
          Una exposición que rindió homenaje al enigmático artista británico Banksy, a través de una cuidada selección de originales certificados, grabados, fotografías, litografías, esculturas, murales, instalaciones de video y reproducciones de sus icónicos stencils, reconocidos mundialmente por su aguda mirada social.
        </p>
        <p>
          La muestra reunió una cuidada selección de originales certificados, grabados, fotografías, litografías, esculturas, murales, instalaciones de video y reproducciones de sus icónicos stencils.
        </p>
        <p>
          MAPAMAPA estuvo a cargo de la producción técnica asegurando el óptimo desarrollo de la muestra en aspectos de iluminación, sonido, montaje y soporte técnico, para que cada pieza y espacio transmitiera con precisión la fuerza estética y política del artista.
        </p>
      </div>

      <figure class="production__card production__card--side reveal reveal-delay-2">
        <img
          src={gallery.expo}
          alt="Sala de la exposición Banksy con obras en exhibición"
          width="572"
          height="363"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--left reveal reveal-delay-3">
        <img
          src={gallery.stencil}
          alt="Stencil icónico de Banksy en la muestra"
          width="472"
          height="487"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--right reveal reveal-delay-3">
        <img
          src={gallery.artwork}
          alt="Obra original certificada de Banksy"
          width="276"
          height="373"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(5.5rem, 8vw, 7rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
  }

  .production__hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__sub {
    font-size: clamp(1rem, 0.8rem + 1.2vw, 1.8rem);
    font-weight: 400;
    text-transform: none;
    color: #999;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__copy {
    grid-column: span 6;
    display: grid;
    gap: 1rem;
    padding-right: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__card--side {
    grid-column: 7 / -1;
  }

  .production__card--left {
    grid-column: 1 / 7;
  }

  .production__card--right {
    grid-column: 7 / -1;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .production__copy,
    .production__card--side,
    .production__card--left,
    .production__card--right {
      grid-column: auto;
    }

    .production__copy {
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }
  }
</style>
