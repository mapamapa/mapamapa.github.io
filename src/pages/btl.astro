---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'BTL';
const description = 'Transformamos ideas en experiencias directas y memorables: activaciones, eventos y campañas que conectan marcas con audiencias.';

const gallery = {
  hero: '/img/btl/hero.jpg',
  activation1: '/img/btl/activation1.jpg',
  activation2: '/img/btl/activation2.jpg',
  activation3: '/img/btl/activation3.jpg',
  activation4: '/img/btl/activation4.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.hero}
          alt="Activación BTL producida por MAPA MAPA con público participando"
          width="1600"
          height="660"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>BTL</h1>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="btl-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="btl-copy-title" class="sr-only">Descripción del servicio</h2>
        <p>
          En MAPAMAPA transformamos ideas en experiencias directas y memorables. Nuestro enfoque BTL
          busca generar contacto cercano entre marcas, artistas y audiencias, creando activaciones,
          eventos y campañas que sorprenden y conectan de manera auténtica.
        </p>
        <p>
          Desde la conceptualización hasta la ejecución, nos encargamos de cada detalle técnico y
          creativo, asegurando que cada acción tenga impacto, visibilidad y recordación en el
          público.
        </p>
      </div>

      <figure class="production__card production__card--tall reveal reveal-delay-2">
        <img
          src={gallery.activation1}
          alt="Montaje y ambientación de campaña BTL"
          width="842"
          height="1264"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--wide reveal reveal-delay-3">
        <img
          src={gallery.activation2}
          alt="Activación de marca con público interactuando"
          width="1308"
          height="784"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--left reveal reveal-delay-4">
        <img
          src={gallery.activation4}
          alt="Evento BTL con asistentes en experiencia inmersiva"
          width="1080"
          height="700"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--right reveal reveal-delay-4">
        <img
          src={gallery.activation3}
          alt="Campaña de marketing experiencial en terreno"
          width="1080"
          height="700"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(2.5rem, 4vw, 4rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
    height: 540px;
  }

  .production__hero img,
  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__copy {
    grid-column: span 6;
    display: grid;
    gap: 1rem;
    padding-right: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card--tall {
    grid-column: 7 / -1;
    grid-row: 1 / 3;
  }

  .production__card--wide {
    grid-column: 1 / 7;
  }

  .production__card--left {
    grid-column: 1 / 7;
  }

  .production__card--right {
    grid-column: 7 / -1;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .production__copy,
    .production__card--tall,
    .production__card--wide,
    .production__card--left,
    .production__card--right {
      grid-column: auto;
      grid-row: auto;
    }

    .production__copy {
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }
  }
</style>
