---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Iván Navarro — Carnavalito';
const description = 'Tercera edición de Carnavalito en el GAM: encuentro entre arte impreso, música independiente y experimentación sonora.';

const gallery = {
  hero: '/img/carnavalito/hero.jpg',
  event1: '/img/carnavalito/event1.jpg',
  event2: '/img/carnavalito/event2.jpg',
  detail1: '/img/carnavalito/detail1.jpg',
  detail2: '/img/carnavalito/detail2.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.hero}
          alt="Carnavalito en el Centro Gabriela Mistral"
          width="1164"
          height="480"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>Iván Navarro — Carnavalito</h1>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="carnavalito-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="carnavalito-copy-title" class="sr-only">Descripción del proyecto</h2>
        <p>
          La tercera edición de CARNAVALITO se realizó con entrada liberada en el Centro Gabriela Mistral (GAM), en el marco de la 17ª Bienal de Artes Mediales de Santiago y bajo el alero de la exposición Penumbra del artista lumínico Iván Navarro, presentada en la Sala de Artes Visuales del centro cultural.
        </p>
        <p>
          Impulsado por el proyecto editorial Se Imprime, junto a Iván Navarro —fundador de Hueso Records—, y en colaboración con MAPAMAPA y la disquería KOLALA, distribuidora oficial del sello, CARNAVALITO propone un encuentro entre arte impreso, música independiente y experimentación sonora, reuniendo a editores, artistas y proyectos musicales en torno a la creación contemporánea.
        </p>
        <p>
          Durante dos jornadas, el evento abrió un espacio para los cruces entre palabra, sonido e imagen, así como para la circulación de propuestas editoriales y discográficas independientes, consolidándose como una plataforma de intercambio, visibilidad y comunidad dentro de la escena cultural actual.
        </p>
      </div>

      <figure class="production__card production__card--side reveal reveal-delay-2">
        <img
          src={gallery.event1}
          alt="Asistentes recorriendo los stands de Carnavalito"
          width="572"
          height="708"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--right reveal reveal-delay-3">
        <img
          src={gallery.event2}
          alt="Artistas y editores durante Carnavalito en GAM"
          width="572"
          height="786"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--d1 reveal reveal-delay-4">
        <img
          src={gallery.detail1}
          alt="Detalle de publicaciones independientes"
          width="276"
          height="388"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--d2 reveal reveal-delay-4">
        <img
          src={gallery.detail2}
          alt="Material editorial en exhibición"
          width="276"
          height="388"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(5.5rem, 8vw, 7rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
  }

  .production__hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__copy {
    grid-column: span 6;
    display: grid;
    gap: 1rem;
    padding-right: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__card--side {
    grid-column: 7 / -1;
    grid-row: 1 / 3;
  }

  .production__card--right {
    grid-column: 7 / -1;
  }

  .production__card--d1 {
    grid-column: 1 / 4;
  }

  .production__card--d2 {
    grid-column: 4 / 7;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .production__copy,
    .production__card--side,
    .production__card--right,
    .production__card--d1,
    .production__card--d2 {
      grid-column: auto;
      grid-row: auto;
    }

    .production__copy {
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }
  }
</style>
