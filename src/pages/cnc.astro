---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'CNC — Clásica No Convencional';
const description = 'CNC transforma espacios inesperados en escenarios únicos donde la música clásica cobra vida de formas que nunca imaginaste.';

const gallery = {
  hero: '/img/work/cnc/hero.jpg',
  portrait: '/img/work/cnc/portrait.jpg',
  scene1: '/img/work/cnc/scene1.jpg',
  scene2: '/img/work/cnc/scene2.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.hero}
          alt="Concierto de música clásica en espacio no convencional"
          width="1600"
          height="660"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>CNC: TRANSFORMANDO LA FORMA DE ESCUCHAR MÚSICA CLÁSICA</h1>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="cnc-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="cnc-copy-title" class="sr-only">Descripción del proyecto</h2>
        <p>
          <strong>Clásica no convencional (CNC)</strong> transforma espacios inesperados en escenarios
          únicos donde la música clásica cobra vida de formas que nunca imaginaste. Nuestro enfoque en
          <strong>producción general y diseño de producción</strong> cuida cada detalle —logístico,
          técnico y creativo— para crear experiencias memorables, accesibles y envolventes.
        </p>
        <p>
          Desplazando la música clásica fuera de los teatros tradicionales, CNC la acerca a nuevos
          territorios y públicos, despertando la curiosidad y el asombro de <strong>niños, jóvenes y
          adultos</strong>.
        </p>
        <p>
          El proyecto combina <strong>interpretaciones de alta calidad</strong> con elementos visuales
          y sensoriales, y promueve la educación musical a través de iniciativas como
          <em>Dentro de la Orquesta</em>. Su propósito es claro: <strong>sorprender, inspirar y dejar
          una huella cultural duradera</strong>, generando experiencias que amplían las formas de
          escuchar y habitar la música clásica.
        </p>
        <p>
          <strong>CNC</strong> es un proyecto colaborativo impulsado por <strong>Mapamapa</strong>,
          <strong>Mapacomún, Needle, Paolo Bortolameolli, Lupa y amigos</strong>, que transforma
          espacios y redefine la relación entre música clásica, territorio y comunidad.
        </p>
      </div>

      <figure class="production__card production__card--portrait reveal reveal-delay-2">
        <img
          src={gallery.portrait}
          alt="Músicos interpretando en espacio no convencional"
          width="851"
          height="1262"
          loading="lazy"
          decoding="async"
        />
      </figure>

    </section>

    <div class="production__bottom-row">
      <figure class="production__card production__card--wide reveal reveal-delay-3">
        <img
          src={gallery.scene1}
          alt="Público asistiendo a concierto CNC en locación inesperada"
          width="1338"
          height="754"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--small reveal reveal-delay-3">
        <img
          src={gallery.scene2}
          alt="Detalle de montaje y ambientación de evento CNC"
          width="848"
          height="558"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </div>

    <p class="production__credits reveal reveal-delay-4">
      [Proyecto colaborativo impulsado por MAPAMAPA. MAPACOMUN, NEEDLE, PAOLO BORTOLAMEOLLI, LUPA Y AMIGOS]
    </p>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(2.5rem, 4vw, 4rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    height: 540px;
  }

  .production__hero img,
  .production__card img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(1.6rem, 1.2rem + 2.2vw, 3.2rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__editorial {
    display: flex;
    gap: var(--space-md);
    align-items: start;
  }

  .production__copy {
    flex: 1 1 58%;
    display: grid;
    gap: 1rem;
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__card {
    overflow: hidden;
  }

  .production__card--portrait {
    flex: 0 0 auto;
    max-width: 402px;
  }

  .production__bottom-row {
    display: flex;
    align-items: flex-end;
    gap: 0;
  }

  .production__card--wide {
    flex: 1 1 55%;
  }

  .production__card--wide img {
    width: 678px;
    max-width: 100%;
  }

  .production__card--small {
    flex: 1 1 45%;
  }

  .production__credits {
    margin-top: var(--space-lg);
    font-size: 0.85rem;
    color: #888;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      flex-direction: column;
    }

    .production__card--portrait {
      max-width: none;
    }

    .production__copy {
      margin-bottom: var(--space-sm);
    }

    .production__bottom-row {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
