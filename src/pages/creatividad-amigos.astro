---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Creatividad & Amigos';
const description = 'Creemos en las ideas que nacen entre amigos. Las imaginamos y las hacemos realidad a través de proyectos culturales colaborativos.';

const gallery = {
  session1: '/img/creatividad/session1.jpg',
  session2: '/img/creatividad/session2.jpg',
  poster: '/img/creatividad/poster.png',
  crowd1: '/img/creatividad/crowd1.jpg',
  crowd2: '/img/creatividad/crowd2.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.session1}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.crowd1}
          alt="Sesión cultural del proyecto UNCLUB organizado por MAPA MAPA"
          width="1600"
          height="660"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>CREATIVIDAD & AMIGOS</h1>
        <span class="production__subtitle">UNCLUB</span>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="creatividad-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="creatividad-copy-title" class="sr-only">Descripción del servicio</h2>
        <p>
          <strong>UNCLUB</strong>, concebido para reunir a nuestra comunidad y dar forma a proyectos
          propios y de amigos, funcionó como un laboratorio cultural donde convergieron música y arte.
        </p>
        <p>
          Desde la curaduría hasta la producción integral, MAPAMAPA potenció este espacio, acogiendo
          sesiones <em>IRL</em>, visitas de destacados DJs internacionales y propuestas locales que
          exploraron nuevas formas de expresión.
        </p>
        <p class="production__cta">
          En MAPAMAPA creemos en las ideas que nacen entre amigos. Las imaginamos y las hacemos
          realidad.
        </p>
      </div>

      <figure class="production__card production__card--portrait1 reveal reveal-delay-2">
        <img
          src={gallery.session2}
          alt="DJ en sesión en vivo durante evento UNCLUB"
          width="552"
          height="756"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--portrait2 reveal reveal-delay-2">
        <img
          src={gallery.session1}
          alt="Público disfrutando de sesión musical en UNCLUB"
          width="552"
          height="756"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--tall reveal reveal-delay-3">
        <img
          src={gallery.poster}
          alt="Afiche gráfico del proyecto UNCLUB"
          width="1144"
          height="1618"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--stack1 reveal reveal-delay-3">
        <img
          src={gallery.crowd1}
          alt="Vista panorámica de evento UNCLUB con audiencia"
          width="1144"
          height="800"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--stack2 reveal reveal-delay-4">
        <img
          src={gallery.crowd2}
          alt="Momento de colaboración y encuentro en evento cultural"
          width="1144"
          height="800"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(5.5rem, 8vw, 7rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
  }

  .production__hero img,
  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__subtitle {
    font-size: clamp(1.2rem, 1rem + 1vw, 2rem);
    color: #b1b1b1;
    font-weight: 400;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__copy {
    grid-column: span 6;
    display: grid;
    gap: 1rem;
    padding-right: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__cta {
    margin-top: 0.5rem;
    font-style: italic;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card--portrait1 {
    grid-column: 7 / 10;
  }

  .production__card--portrait2 {
    grid-column: 10 / -1;
  }

  .production__card--tall {
    grid-column: 1 / 7;
    grid-row: span 2;
  }

  .production__card--stack1 {
    grid-column: 7 / -1;
  }

  .production__card--stack2 {
    grid-column: 7 / -1;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr 1fr;
      gap: 0;
    }

    .production__copy {
      grid-column: 1 / -1;
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }

    .production__card--portrait1,
    .production__card--portrait2 {
      grid-column: auto;
    }

    .production__card--tall,
    .production__card--stack1,
    .production__card--stack2 {
      grid-column: 1 / -1;
      grid-row: auto;
    }
  }
</style>
