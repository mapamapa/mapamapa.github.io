---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Editoriales';
const description = 'Damos forma a historias visuales a través de proyectos editoriales que van desde fanzines hasta libros de artistas.';

const gallery = {
  hero: '/img/editoriales/hero.jpg',
  book1: '/img/editoriales/book1.jpg',
  book2: '/img/editoriales/book2.jpg',
  book3: '/img/editoriales/book3.jpg',
  spread: '/img/editoriales/spread.jpg',
  detail: '/img/editoriales/detail.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.hero}
          alt="Publicación editorial abierta sobre una mesa de trabajo"
          width="1600"
          height="660"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>EDITORIALES</h1>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="editorial-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="editorial-copy-title" class="sr-only">Descripción del servicio</h2>
        <p>
          En MAPAMAPA damos forma a historias visuales a través de proyectos editoriales que van
          desde fanzines hasta libros de artistas.
        </p>
        <p>
          Más que imprimir páginas, transformamos ideas en publicaciones únicas. Acompañamos todo el
          proceso, desde la conceptualización hasta la impresión y distribución, cuidando cada
          detalle gráfico y narrativo.
        </p>
      </div>

      <figure class="production__card production__card--a reveal reveal-delay-2">
        <img
          src={gallery.book2}
          alt="Portada de publicación editorial producida por MAPA MAPA"
          width="480"
          height="700"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--b reveal reveal-delay-2">
        <img
          src={gallery.book1}
          alt="Interior de fanzine con diseño gráfico editorial"
          width="480"
          height="700"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--c reveal reveal-delay-3">
        <img
          src={gallery.book3}
          alt="Detalle de encuadernación artesanal de libro de artista"
          width="480"
          height="700"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--wide reveal reveal-delay-3">
        <img
          src={gallery.detail}
          alt="Proceso de producción editorial en taller de impresión"
          width="690"
          height="944"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--feature reveal reveal-delay-4">
        <img
          src={gallery.spread}
          alt="Doble página de publicación editorial con fotografía"
          width="1508"
          height="944"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(5.5rem, 8vw, 7rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
  }

  .production__hero img,
  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__copy {
    grid-column: span 6;
    display: grid;
    gap: 1rem;
    padding-right: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card--a {
    grid-column: 7 / 9;
  }

  .production__card--b {
    grid-column: 9 / 11;
  }

  .production__card--c {
    grid-column: 11 / -1;
  }

  .production__card--wide {
    grid-column: 1 / 5;
  }

  .production__card--feature {
    grid-column: 5 / -1;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr 1fr;
      gap: 0;
    }

    .production__copy {
      grid-column: 1 / -1;
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }

    .production__card--a,
    .production__card--b,
    .production__card--c {
      grid-column: auto;
    }

    .production__card--wide,
    .production__card--feature {
      grid-column: 1 / -1;
    }
  }
</style>
