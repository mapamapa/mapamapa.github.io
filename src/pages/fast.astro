---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'FAST — Festival de Arte Contemporáneo';
const description = 'FAST acerca las artes contemporáneas al público general como un soporte dinámico donde convergen múltiples expresiones.';

const gallery = {
  hero: '/img/work/fast/hero.jpg',
  inline: '/img/work/fast/inline.jpg',
  grid1: '/img/work/fast/grid1.jpg',
  grid2: '/img/work/fast/grid2.jpg',
  col1: '/img/work/fast/col1.jpg',
  col2: '/img/work/fast/col2.jpg',
  col3: '/img/work/fast/col3.jpg',
  col4: '/img/work/fast/col4.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.hero}
          alt="Escena del festival FAST con instalaciones de arte contemporáneo"
          width="1600"
          height="660"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>FAST</h1>
        <span class="production__subtitle">ACERCANDO LAS ARTES CONTEMPORÁNEAS A TODO PÚBLICO</span>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="fast-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="fast-copy-title" class="sr-only">Descripción del proyecto</h2>
        <p>
          FAST nace con un objetivo claro: acercar las artes contemporáneas al público general. Se
          establece como un soporte dinámico para diversas formas de expresión artística.
        </p>
        <p>
          No es un lugar fijo ni un evento convencional: FAST es un momento, una exposición. Su tiempo
          es variable y su esencia, un vórtice donde convergen múltiples expresiones contemporáneas,
          poniendo al arte en el centro y dejando que todo lo demás se vuelva relativo.
        </p>
        <p>
          En MAPAMAPA nos encargamos de la producción general, asegurando que cada edición de FAST
          funcione como un espacio vivo y envolvente, una experiencia completa que permite a los
          artistas enfocarse en crear mientras la experiencia cobra vida e impacta al público con
          integración fluida donde logística, montaje y coordinación se unen con la propuesta artística
          de forma coherente.
        </p>
      </div>

      <figure class="production__card production__card--side reveal reveal-delay-2">
        <img
          src={gallery.inline}
          alt="Obra de arte contemporáneo exhibida en FAST"
          width="1144"
          height="630"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--left reveal reveal-delay-3">
        <img
          src={gallery.grid1}
          alt="Instalación artística en el festival FAST"
          width="1140"
          height="760"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--right reveal reveal-delay-3">
        <img
          src={gallery.grid2}
          alt="Público interactuando con obras durante FAST"
          width="1140"
          height="760"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q1 reveal reveal-delay-4">
        <img
          src={gallery.col1}
          alt="Detalle de pieza artística en FAST"
          width="552"
          height="828"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q2 reveal reveal-delay-4">
        <img
          src={gallery.col2}
          alt="Experiencia inmersiva en el festival"
          width="552"
          height="828"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q3 reveal reveal-delay-4">
        <img
          src={gallery.col3}
          alt="Montaje y producción del festival FAST"
          width="552"
          height="828"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q4 reveal reveal-delay-4">
        <img
          src={gallery.col4}
          alt="Visitantes del festival FAST"
          width="552"
          height="828"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>

    <p class="production__credits reveal reveal-delay-4">
      [Proyecto colaborativo con MAPACOMUN]
    </p>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(2.5rem, 4vw, 4rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
    height: 540px;
  }

  .production__hero img,
  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__subtitle {
    font-size: clamp(1.1rem, 0.9rem + 1vw, 1.8rem);
    color: #b1b1b1;
    font-weight: 400;
    text-transform: uppercase;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__copy {
    grid-column: span 6;
    display: grid;
    gap: 1rem;
    padding-right: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card--side {
    grid-column: 7 / -1;
  }

  .production__card--left {
    grid-column: 1 / 7;
  }

  .production__card--right {
    grid-column: 7 / -1;
  }

  .production__card--q1 {
    grid-column: 1 / 4;
  }

  .production__card--q2 {
    grid-column: 4 / 7;
  }

  .production__card--q3 {
    grid-column: 7 / 10;
  }

  .production__card--q4 {
    grid-column: 10 / -1;
  }

  .production__credits {
    margin-top: var(--space-lg);
    font-size: 0.85rem;
    color: #888;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr 1fr;
      gap: 0;
    }

    .production__copy {
      grid-column: 1 / -1;
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }

    .production__card--side,
    .production__card--left,
    .production__card--right {
      grid-column: 1 / -1;
    }

    .production__card--q1,
    .production__card--q2,
    .production__card--q3,
    .production__card--q4 {
      grid-column: auto;
    }
  }
</style>
