---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Host Producer';
const description = 'Diseñamos y gestionamos experiencias desde dentro, siendo el puente entre la idea y la ejecución con coherencia y personalidad.';

const gallery = {
  hero: '/img/ghost-producers/hero.jpg',
  event1: '/img/ghost-producers/event1.jpg',
  event2: '/img/ghost-producers/event2.jpg',
  event3: '/img/ghost-producers/event3.jpg',
  event4: '/img/ghost-producers/event4.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.hero}
          alt="Producción de evento gestionado por MAPA MAPA como ghost producer"
          width="1600"
          height="660"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>HOST PRODUCER</h1>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="host-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="host-copy-title" class="sr-only">Descripción del servicio</h2>
        <p>
          En MAPAMAPA diseñamos y gestionamos experiencias desde dentro. Como ghost producers nos
          encargamos de ser el puente entre la idea y la ejecución: acompañamos a artistas, marcas,
          agencias o instituciones en todo el proceso, asegurándonos de que cada detalle —logística,
          producción y relato— fluya con coherencia y personalidad.
        </p>
      </div>

      <figure class="production__card production__card--left reveal reveal-delay-2">
        <img
          src={gallery.event1}
          alt="Gestión y coordinación de experiencia en vivo"
          width="1150"
          height="718"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--right reveal reveal-delay-2">
        <img
          src={gallery.event2}
          alt="Producción de evento con asistentes y ambientación"
          width="1150"
          height="718"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--narrow reveal reveal-delay-3">
        <img
          src={gallery.event4}
          alt="Detalle de montaje y logística de evento"
          width="720"
          height="1054"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--feature reveal reveal-delay-3">
        <img
          src={gallery.event3}
          alt="Panorámica de evento producido como ghost producer"
          width="1570"
          height="1054"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(5.5rem, 8vw, 7rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
  }

  .production__hero img,
  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__copy {
    grid-column: span 6;
    display: grid;
    gap: 1rem;
    padding-right: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card--left {
    grid-column: 1 / 7;
  }

  .production__card--right {
    grid-column: 7 / -1;
  }

  .production__card--narrow {
    grid-column: 1 / 5;
  }

  .production__card--feature {
    grid-column: 5 / -1;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .production__copy,
    .production__card--left,
    .production__card--right,
    .production__card--narrow,
    .production__card--feature {
      grid-column: auto;
    }

    .production__copy {
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }
  }
</style>
