---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Librería Nacional — Concurso Arte en Vivo';
const description = 'Diseño de producción para el concurso Arte en Vivo de Librería Nacional: una experiencia cultural de estudio abierto con artistas emergentes.';

const gallery = {
  hero: '/img/libreria-nacional/expo1.jpg',
  expo2: '/img/libreria-nacional/expo2.jpg',
  expo3: '/img/libreria-nacional/expo3.jpg',
  expo4: '/img/libreria-nacional/expo4.jpg',
  expo5: '/img/libreria-nacional/expo5.jpg',
  closing: '/img/libreria-nacional/closing.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.hero}
          alt="Artista trabajando en vivo durante el concurso Arte en Vivo"
          width="498"
          height="424"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>Diseño de Producción</h1>
        <p class="production__subtitle">Librería Nacional — Concurso "Arte en Vivo"</p>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="libreria-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="libreria-copy-title" class="sr-only">Descripción del proyecto</h2>
        <p>
          El concurso "Arte en Vivo", creado por Librería Nacional, es una iniciativa orientada a promover las artes visuales en el país, apoyar a artistas emergentes e impulsar sus carreras. Como parte de esta propuesta, se buscó abrir los procesos creativos al público, generando un formato de estudio abierto en el que los asistentes pudieran observar en directo la elaboración de las obras seleccionadas y conocer de cerca las metodologías de trabajo de cada artista.
        </p>
        <p>
          Desde MAPA acompañamos la producción del proyecto, diseñando y ejecutando la puesta en marcha de la exposición en vivo. Nuestro trabajo consistió en traducir la idea de Librería Nacional en una experiencia cultural tangible, en la que el vínculo entre artistas y comunidad se fortaleciera a través de la interacción directa con los procesos creativos.
        </p>
        <p>
          De esta forma, "Arte en Vivo" se consolidó no solo como una plataforma para visibilizar el talento emergente, sino también como un espacio innovador de encuentro y apreciación del arte contemporáneo joven.
        </p>
      </div>

      <figure class="production__card production__card--side reveal reveal-delay-2">
        <img
          src={gallery.expo2}
          alt="Obra en proceso durante la exposición"
          width="572"
          height="432"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--left reveal reveal-delay-3">
        <img
          src={gallery.expo3}
          alt="Visitantes observando el proceso creativo"
          width="572"
          height="360"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--right reveal reveal-delay-3">
        <img
          src={gallery.expo4}
          alt="Artista emergente trabajando en su obra"
          width="572"
          height="461"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--left reveal reveal-delay-4">
        <img
          src={gallery.expo5}
          alt="Espacio de la exposición Arte en Vivo"
          width="570"
          height="390"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>

    <figure class="production__closing reveal reveal-delay-4">
      <img
        src={gallery.closing}
        alt="Vista general del concurso Arte en Vivo en Librería Nacional"
        width="1162"
        height="577"
        loading="lazy"
        decoding="async"
      />
    </figure>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(2.5rem, 4vw, 4rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
    height: 540px;
  }

  .production__closing {
    margin-top: 0;
    overflow: hidden;
    background: #060606;
  }

  .production__hero img,
  .production__card img,
  .production__closing img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__subtitle {
    font-size: clamp(1rem, 0.8rem + 1.2vw, 1.5rem);
    color: #999;
    line-height: 1.1;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__copy {
    grid-column: span 6;
    display: grid;
    gap: 1rem;
    padding-right: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card--side {
    grid-column: 7 / -1;
  }

  .production__card--left {
    grid-column: 1 / 7;
  }

  .production__card--right {
    grid-column: 7 / -1;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .production__copy,
    .production__card--side,
    .production__card--left,
    .production__card--right {
      grid-column: auto;
    }

    .production__copy {
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }
  }
</style>
