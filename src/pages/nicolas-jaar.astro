---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Nicolas Jaar — Ladridos & Radio Piedras';
const description = 'Producción de los lanzamientos de Ladridos y Radio Piedras de Nicolas Jaar: encuentro cultural interdisciplinario y radioteatro en 17 capítulos.';

const gallery = {
  hero: '/img/nicolas-jaar/hero.jpg',
  ladridos1: '/img/nicolas-jaar/ladridos1.jpg',
  ladridos2: '/img/nicolas-jaar/ladridos2.jpg',
  ladridos3: '/img/nicolas-jaar/ladridos3.jpg',
  radio1: '/img/nicolas-jaar/radio1.jpg',
  radio2: '/img/nicolas-jaar/radio2.jpg',
};

const carouselSlides = [
  '/img/nicolas-jaar/carousel/slide01.png',
  '/img/nicolas-jaar/carousel/slide02.png',
  '/img/nicolas-jaar/carousel/slide03.png',
  '/img/nicolas-jaar/carousel/slide04.png',
  '/img/nicolas-jaar/carousel/slide05.png',
  '/img/nicolas-jaar/carousel/slide06.png',
  '/img/nicolas-jaar/carousel/slide07.png',
  '/img/nicolas-jaar/carousel/slide08.png',
  '/img/nicolas-jaar/carousel/slide09.png',
  '/img/nicolas-jaar/carousel/slide10.png',
  '/img/nicolas-jaar/carousel/slide11.png',
];
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.hero}
          alt="Nicolas Jaar — evento de lanzamiento"
          width="1164"
          height="480"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>Nicolas Jaar</h1>
        <p class="production__subtitle">Lanzamiento discos: Ladridos & Radio Piedras</p>
      </div>
    </header>

    <!-- LADRIDOS -->
    <section class="production__editorial" aria-labelledby="ladridos-title">
      <div class="production__pair reveal reveal-delay-2">
        <div class="production__pair-left">
          <div class="production__copy">
            <img src="/social/logos/grieta.png" alt="Grieta" class="production__collab-logo" width="120" height="auto" decoding="async" />
            <h2 id="ladridos-title">Ladridos</h2>
            <p>
              Encuentro cultural gratuito desplegado en los galpones del Persa Biobío, CEINA y Galería CIMA, que reunió música en vivo, artes visuales, instalaciones, IA, performance y espacios de conversación en torno a la pregunta: ¿Qué significa ser de aquí?
            </p>
            <p>
              Con la participación de artistas locales e internacionales, MAPAMAPA colaboró en la producción de esta experiencia interdisciplinaria que exploró territorio, identidad y pertenencia desde múltiples miradas, culminando en una fiesta de cierre en PARKING.
            </p>
          </div>
          <figure class="production__card">
            <img
              src={gallery.ladridos2}
              alt="Instalación artística durante Ladridos"
              width="746"
              height="288"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>
        <figure class="production__card">
          <img
            src={gallery.ladridos1}
            alt="Evento Ladridos en el Persa Biobío"
            width="397"
            height="548"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>

      <figure class="production__card production__card--full reveal reveal-delay-3">
        <img
          src={gallery.ladridos3}
          alt="Vista general del encuentro Ladridos"
          width="1166"
          height="340"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>

    <!-- RADIOPIEDRA -->
    <section class="production__editorial production__editorial--radio" aria-labelledby="radio-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="radio-title">Radiopiedra</h2>
        <p>
          Radioteatro en 17 capítulos ambientado en un Chile distópico, donde un apagón digital obliga a comunicarse mediante radios. A través de ficción y archivos históricos, la obra reflexiona sobre memoria, migración y luchas sociales.
        </p>
        <p>
          MAPAMAPA apoyó en la producción creando junto a GrietaMag una experiencia sonora crítica y contemplativa.
        </p>
      </div>

      <div class="production__pair reveal reveal-delay-3">
        <figure class="production__card">
          <img
            src={gallery.radio2}
            alt="Producción de Radiopiedra en estudio"
            width="572"
            height="305"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <figure class="production__card">
          <img
            src={gallery.radio1}
            alt="Sesión de grabación de Radiopiedra"
            width="572"
            height="398"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
    </section>

    <div class="carousel reveal reveal-delay-3" id="jaar-carousel">
      <div class="carousel__track" id="jaar-track">
        {carouselSlides.map((src) => (
          <img
            src={src}
            alt=""
            width="1600"
            height="1067"
            loading="lazy"
            decoding="async"
          />
        ))}
      </div>
      <button class="carousel__arrow carousel__arrow--prev" id="jaar-prev" aria-label="Anterior">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 18l-6-6 6-6" />
        </svg>
      </button>
      <button class="carousel__arrow carousel__arrow--next" id="jaar-next" aria-label="Siguiente">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6" />
        </svg>
      </button>
    </div>

    <p class="production__note reveal reveal-delay-4">[Una iniciativa de GrietaMag producida por MAPAMAPA]</p>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(2.5rem, 4vw, 4rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
    height: 540px;
  }

  .production__hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__subtitle {
    font-size: clamp(1rem, 0.8rem + 1.2vw, 1.5rem);
    color: #999;
    line-height: 1.1;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
    margin-bottom: var(--space-lg);
  }

  .production__editorial--radio {
    margin-bottom: var(--space-md);
  }

  .production__copy {
    grid-column: span 6;
    display: grid;
    gap: 1rem;
    padding-right: var(--space-md);
  }

  .production__copy h2 {
    font-size: clamp(1.4rem, 1.1rem + 1.5vw, 2.2rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__pair {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: 0;
    align-items: end;
  }

  .production__pair .production__card {
    min-height: auto;
  }

  .production__pair-left {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .production__collab-logo {
    width: 360px;
    height: auto;
    clip-path: inset(36% 0 34% 0);
    margin-top: -130px;
    margin-bottom: -122px;
  }

  .production__pair-left .production__copy {
    grid-column: auto;
    padding-right: 0;
    margin-bottom: var(--space-sm);
  }

  .production__card--side {
    grid-column: 7 / -1;
  }

  .production__card--wide {
    grid-column: 1 / 8;
  }

  .production__card--full {
    grid-column: 1 / -1;
  }

  .production__card--left {
    grid-column: 1 / 7;
  }

  .carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
    margin-top: var(--space-lg);
  }

  .carousel__track {
    display: flex;
    height: 500px;
  }

  .carousel__track img {
    width: 100%;
    height: 100%;
    flex-shrink: 0;
    object-fit: cover;
    display: block;
  }

  .carousel__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    cursor: pointer;
    transition: background-color var(--duration-fast), border-color var(--duration-fast);
    z-index: 2;
  }

  .carousel__arrow:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .carousel__arrow--prev { left: 12px; }
  .carousel__arrow--next { right: 12px; }

  @media (max-width: 599px) {
    .carousel__track {
      height: 300px;
    }

    .carousel__arrow {
      width: 36px;
      height: 36px;
    }

    .carousel__arrow--prev { left: 8px; }
    .carousel__arrow--next { right: 8px; }
  }

  .production__note {
    text-align: center;
    font-size: 0.85rem;
    font-style: italic;
    color: #888;
    margin-top: var(--space-md);
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .production__copy,
    .production__card--side,
    .production__card--wide,
    .production__card--full,
    .production__card--left {
      grid-column: auto;
    }

    .production__copy {
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }
  }
</style>

<script>
  import { gsap } from '@/scripts/gsap';

  function initCarousel() {
    const track = document.getElementById('jaar-track');
    const prevBtn = document.getElementById('jaar-prev');
    const nextBtn = document.getElementById('jaar-next');
    if (!track || !prevBtn || !nextBtn) return;

    const slides = track.querySelectorAll('img');
    const total = slides.length;
    let current = 0;
    let animating = false;

    function goTo(index: number) {
      if (animating) return;
      animating = true;
      current = (index + total) % total;
      gsap.to(track, {
        xPercent: -current * 100,
        duration: 0.6,
        ease: 'expo.out',
        onComplete: () => { animating = false; },
      });
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    let startX = 0;
    const carousel = document.getElementById('jaar-carousel');
    if (!carousel) return;

    carousel.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
    }, { passive: true });

    carousel.addEventListener('touchend', (e) => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        goTo(diff > 0 ? current + 1 : current - 1);
      }
    }, { passive: true });
  }

  document.addEventListener('astro:page-load', initCarousel);
</script>
