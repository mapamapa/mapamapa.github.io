---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'PARKING — Locación';
const description = 'Un estacionamiento subterráneo en nivel –6 que se transforma en un espacio modular y adaptable para todo tipo de experiencias.';

const gallery = {
  hero: '/img/work/parking/hero.jpg',
  space1: '/img/work/parking/space1.jpg',
  space2: '/img/work/parking/space2.jpg',
};

const carousel = [
  '/img/work/parking/carousel1.png',
  '/img/work/parking/carousel2.png',
  '/img/work/parking/carousel3.png',
  '/img/work/parking/carousel4.png',
  '/img/work/parking/carousel5.png',
  '/img/work/parking/carousel6.png',
  '/img/work/parking/carousel7.png',
  '/img/work/parking/carousel8.png',
  '/img/work/parking/carousel9.png',
];
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.hero}
          alt="Estacionamiento subterráneo PARKING transformado en espacio cultural"
          width="1600"
          height="660"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>PARKING</h1>
        <span class="production__subtitle">ESPACIO EN CONSTANTE TRANSFORMACIÓN</span>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="parking-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="parking-copy-title" class="sr-only">Descripción del proyecto</h2>
        <p>
          PARKING es una de las locaciones más singulares de MAPAMAPA y MAPACOMUN: un estacionamiento subterráneo ubicado en el nivel –6 que se transforma en un espacio modular y adaptable para
          todo tipo de experiencias.
        </p>
        <p>
          Su carácter industrial y su arquitectura flexible permiten reinterpretar el lugar en cada
          evento, convirtiéndolo en un escenario único que desafía lo convencional.
        </p>
      </div>

      <figure class="production__card production__card--left reveal reveal-delay-2">
        <img
          src={gallery.space1}
          alt="Interior del estacionamiento transformado en locación de evento"
          width="1144"
          height="566"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--right reveal reveal-delay-2">
        <img
          src={gallery.space2}
          alt="Montaje e iluminación en el espacio subterráneo PARKING"
          width="1144"
          height="566"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <p class="production__bottom-copy reveal reveal-delay-3">
        PARKING es un espacio que desafía las convenciones tradicionales y da libertad total a la
        creación. Cada montaje, iluminación o disposición espacial propone una nueva forma de
        habitar lo subterráneo.
      </p>
    </section>

    <div class="carousel reveal reveal-delay-3">
      <div class="carousel__track">
        {[...carousel, carousel[0]].map((src) => (
          <img
            src={src}
            alt=""
            width="1600"
            height="1067"
            loading="lazy"
            decoding="async"
          />
        ))}
      </div>
    </div>

    <p class="production__credits reveal reveal-delay-3">
      [Proyecto conjunto con MAPACOMUN]
    </p>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(2.5rem, 4vw, 4rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
    height: 540px;
  }

  .production__hero img,
  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__subtitle {
    font-size: clamp(1.1rem, 0.9rem + 1vw, 1.8rem);
    color: #b1b1b1;
    font-weight: 400;
    text-transform: uppercase;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__copy {
    grid-column: span 12;
    display: grid;
    gap: 1rem;
    margin-bottom: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
  }

  .production__bottom-copy {
    grid-column: 1 / -1;
    margin-top: var(--space-md);
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card--left {
    grid-column: 1 / 7;
  }

  .production__card--right {
    grid-column: 7 / -1;
  }

  .carousel {
    overflow: hidden;
    margin-top: var(--space-md);
    width: 900px;
    max-width: 100%;
    margin-inline: auto;
  }

  .carousel__track {
    display: flex;
    height: 430px;
    animation: carousel-slide 36s ease-in-out infinite;
  }

  .carousel__track img {
    width: 900px;
    height: 430px;
    flex-shrink: 0;
    object-fit: cover;
    display: block;
  }

  @keyframes carousel-slide {
    0%, 9%     { transform: translateX(0); }
    10%, 19%   { transform: translateX(-900px); }
    20%, 29%   { transform: translateX(-1800px); }
    30%, 39%   { transform: translateX(-2700px); }
    40%, 49%   { transform: translateX(-3600px); }
    50%, 59%   { transform: translateX(-4500px); }
    60%, 69%   { transform: translateX(-5400px); }
    70%, 79%   { transform: translateX(-6300px); }
    80%, 100%  { transform: translateX(-7200px); }
  }

  .production__credits {
    margin-top: var(--space-lg);
    font-size: 0.85rem;
    color: #888;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      max-width: 100%;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .production__copy,
    .production__card--left,
    .production__card--right {
      grid-column: auto;
    }
  }
</style>
