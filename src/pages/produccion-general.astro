---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Producción General y Diseño de Producción';
const description = 'Gestión integral de proyectos: coordinación, planificación, logística, presupuestos y ejecución de experiencias con identidad y sentido.';

const gallery = {
  hero: '/img/prod-gene/WALMART.jpg',
  stage: '/img/prod-gene/WALLMART4.jpg',
  rooftop: '/img/prod-gene/UNILEVER.jpg',
  bags: '/img/prod-gene/WALLMART.jpg',
  kit: '/img/prod-gene/WALLMART(1).jpg',
  night: '/img/prod-gene/ECLIPSE CONDORIACO(1).jpg',
  closing: '/img/prod-gene/ECLIPSE CONDORIACO.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.hero}
          alt="Equipo de producción general coordinando un evento en vivo"
          width="1600"
          height="1067"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>PRODUCCIÓN general y diseño de producción</h1>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="production-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="production-copy-title" class="sr-only">Descripción del servicio</h2>
        <p>
          La producción general es el eje que articula y hace posible un proyecto. Se encarga de
          coordinar, planificar y ejecutar todas las áreas necesarias para que una idea se
          materialice de forma coherente, eficiente y alineada con su visión creativa.
        </p>
        <p>
          Incluye la gestión de presupuestos, cronogramas, equipos humanos, logística, proveedores
          y recursos técnicos, así como la supervisión de cada etapa del proceso: desde el
          desarrollo inicial hasta la ejecución en terreno y el cierre del proyecto. Nuestro
          objetivo es anticipar problemas, optimizar recursos y asegurar que cada proyecto se
          desarrolle con fluidez, identidad y sentido.
        </p>
      </div>

      <figure class="production__card production__card--stage reveal reveal-delay-2">
        <img
          src={gallery.stage}
          alt="Cobertura audiovisual y registro técnico de una presentación en vivo"
          width="1600"
          height="1067"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--rooftop reveal reveal-delay-3">
        <img
          src={gallery.rooftop}
          alt="Activación de marca y escenario en terraza al atardecer"
          width="1600"
          height="1067"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--bags reveal reveal-delay-3">
        <img
          src={gallery.bags}
          alt="Material de apoyo y merchandising preparado para asistentes"
          width="1600"
          height="1067"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--kit reveal reveal-delay-4">
        <img
          src={gallery.kit}
          alt="Detalle de piezas gráficas y kit de marca producidos para el evento"
          width="1600"
          height="1067"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--night reveal reveal-delay-4">
        <img
          src={gallery.night}
          alt="Público y ambientación lumínica en una experiencia inmersiva"
          width="1600"
          height="1067"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>

    <figure class="production__closing reveal reveal-delay-4">
      <img
        src={gallery.closing}
        alt="Instalación y campamento de producción bajo el cielo nocturno"
        width="1600"
        height="1067"
        loading="lazy"
        decoding="async"
      />
    </figure>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(2.5rem, 4vw, 4rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
    height: 540px;
  }

  .production__closing {
    margin-top: 0;
    overflow: hidden;
    background: #060606;
  }

  .production__hero img,
  .production__card img,
  .production__closing img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
    max-width: none;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__copy {
    grid-column: span 6;
    display: grid;
    gap: 1rem;
    padding-right: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card--stage {
    grid-column: 7 / -1;
  }

  .production__card--rooftop {
    grid-column: 1 / 7;
  }

  .production__card--bags {
    grid-column: 7 / -1;
  }

  .production__card--kit {
    grid-column: 1 / 7;
  }

  .production__card--night {
    grid-column: 7 / -1;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .production__copy,
    .production__card--stage,
    .production__card--rooftop,
    .production__card--bags,
    .production__card--kit,
    .production__card--night {
      grid-column: auto;
    }

    .production__copy {
      padding-right: 0;
    }
  }
</style>
