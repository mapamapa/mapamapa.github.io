---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'Producción Técnica';
const description = 'Soluciones técnicas de iluminación, sonido, energía y montaje para que cada proyecto creativo se haga realidad.';

const gallery = {
  hero: '/img/produccion-tecnica/hero.jpg',
  lights: '/img/produccion-tecnica/lights.jpg',
  rigging1: '/img/produccion-tecnica/rigging1.jpg',
  rigging2: '/img/produccion-tecnica/rigging2.jpg',
  rigging3: '/img/produccion-tecnica/rigging3.jpg',
  rigging4: '/img/produccion-tecnica/rigging4.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.hero}
          alt="Instalación lumínica en evento producido por MAPA MAPA"
          width="1600"
          height="660"
          fetchpriority="high"
          decoding="async"
        />
        <figcaption class="production__caption">
          No dejes morir mis llamas — Delight Lab. Iluminación y montaje técnico de 34+
        </figcaption>
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>PRODUCCIÓN TÉCNICA</h1>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="tecnica-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="tecnica-copy-title" class="sr-only">Descripción del servicio</h2>
        <p>
          En MAPAMAPA entendemos que cada proyecto creativo requiere soluciones técnicas precisas para
          que la visión se haga realidad. Nuestro servicio de producción técnica se centra en resolver
          desafíos específicos de iluminación, sonido, energía y demás requerimientos técnicos,
          asegurando que cada detalle funcione a la perfección.
        </p>
        <p>
          Más que brindar soporte, nos encargamos de anticipar problemas, optimizar recursos y
          garantizar que la experiencia fluya sin interrupciones. Desde instalaciones complejas hasta
          montajes técnicos de gran escala, nuestro equipo gestiona cada aspecto con precisión y
          compromiso.
        </p>
      </div>

      <figure class="production__card production__card--side reveal reveal-delay-2">
        <img
          src={gallery.lights}
          alt="Montaje de iluminación técnica para experiencia inmersiva"
          width="1044"
          height="592"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q1 reveal reveal-delay-3">
        <img
          src={gallery.rigging3}
          alt="Instalación de estructura técnica y rigging"
          width="542"
          height="800"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q2 reveal reveal-delay-3">
        <img
          src={gallery.rigging4}
          alt="Detalle de conexiones y equipamiento técnico"
          width="542"
          height="800"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q3 reveal reveal-delay-4">
        <img
          src={gallery.rigging2}
          alt="Equipo técnico durante montaje de producción"
          width="542"
          height="800"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--q4 reveal reveal-delay-4">
        <img
          src={gallery.rigging1}
          alt="Resultado final de producción técnica en evento"
          width="542"
          height="800"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(2.5rem, 4vw, 4rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
    position: relative;
    height: 540px;
  }

  .production__caption {
    position: absolute;
    bottom: 0.75rem;
    right: 1rem;
    font-size: 0.7rem;
    font-weight: 700;
    font-style: italic;
    color: var(--color-bg, #0a0a0a);
    text-align: right;
    background: var(--color-accent, #df9de5);
    padding: 0.15em 0.35em;
    line-height: 1.5;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
  }

  .production__hero img,
  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__copy {
    grid-column: span 6;
    display: grid;
    gap: 1rem;
    padding-right: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card--side {
    grid-column: 7 / -1;
  }

  .production__card--q1 {
    grid-column: 1 / 4;
  }

  .production__card--q2 {
    grid-column: 4 / 7;
  }

  .production__card--q3 {
    grid-column: 7 / 10;
  }

  .production__card--q4 {
    grid-column: 10 / -1;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 599px) {
    .production__hero img {
      object-position: right;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr 1fr;
      gap: 0;
    }

    .production__copy {
      grid-column: 1 / -1;
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }

    .production__card--side {
      grid-column: 1 / -1;
    }

    .production__card--q1,
    .production__card--q2,
    .production__card--q3,
    .production__card--q4 {
      grid-column: auto;
    }
  }
</style>
