---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'SATURNALIA — Celebración del Vino';
const description = 'Celebración dedicada al vino, la música y la cultura que reúne viñas de autor, destilerías, música en vivo y restaurantes pop-up.';

const gallery = {
  hero: '/img/work/saturnalia/hero.jpg',
  slide2: '/img/work/saturnalia/slide2.jpg',
  slide3: '/img/work/saturnalia/slide3.jpg',
  slide4: '/img/work/saturnalia/slide4.jpg',
  slide5: '/img/work/saturnalia/slide5.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <img
          src={gallery.hero}
          alt="Celebración SATURNALIA con vino, música y cultura"
          width="1600"
          height="660"
          fetchpriority="high"
          decoding="async"
        />
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>SATURNALIA</h1>
        <span class="production__subtitle">CELEBRACIÓN DEDICADA AL VINO, LA MÚSICA Y LA CULTURA</span>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="saturnalia-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="saturnalia-copy-title" class="sr-only">Descripción del proyecto</h2>
        <p>
          Un encuentro que reúne a viñas de autor nacionales, destilerías, tiendas de vinilos, música
          en vivo y restaurantes pop-up.
        </p>
        <p>
          Con una propuesta curada y producida por MAPAMAPA, SATURNALIA busca conectar a quienes
          disfrutan de los mostos, los sonidos y los buenos encuentros, transformando la experiencia
          del vino en una verdadera fiesta cultural.
        </p>
        <p>
          Es un evento que celebra la diversidad, el oficio y el espíritu libre de quienes hacen del
          arte y el sabor una forma de vida.
        </p>
      </div>

      <figure class="production__card production__card--side reveal reveal-delay-2">
        <img
          src={gallery.slide2}
          alt="Viñas y degustación en SATURNALIA"
          width="1600"
          height="1067"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--left reveal reveal-delay-3">
        <img
          src={gallery.slide3}
          alt="Música en vivo durante la celebración SATURNALIA"
          width="1600"
          height="1067"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--right reveal reveal-delay-3">
        <img
          src={gallery.slide4}
          alt="Ambiente y asistentes de la fiesta cultural"
          width="1600"
          height="1067"
          loading="lazy"
          decoding="async"
        />
      </figure>

      <figure class="production__card production__card--full reveal reveal-delay-4">
        <img
          src={gallery.slide5}
          alt="Vista panorámica del evento SATURNALIA"
          width="1600"
          height="1067"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </section>

    <p class="production__credits reveal reveal-delay-4">
      Proyecto desarrollado con MAPACOMUN
    </p>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(5.5rem, 8vw, 7rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
  }

  .production__hero img,
  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__subtitle {
    font-size: clamp(1.1rem, 0.9rem + 1vw, 1.8rem);
    color: #b1b1b1;
    font-weight: 400;
    text-transform: uppercase;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: start;
  }

  .production__copy {
    grid-column: span 6;
    display: grid;
    gap: 1rem;
    padding-right: var(--space-md);
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 58ch;
  }

  .production__card {
    overflow: hidden;
    background: #060606;
    min-height: 100%;
  }

  .production__card--side {
    grid-column: 7 / -1;
  }

  .production__card--left {
    grid-column: 1 / 7;
  }

  .production__card--right {
    grid-column: 7 / -1;
  }

  .production__card--full {
    grid-column: 1 / -1;
  }

  .production__credits {
    margin-top: var(--space-lg);
    font-size: 0.85rem;
    color: #888;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .production__copy,
    .production__card--side,
    .production__card--left,
    .production__card--right,
    .production__card--full {
      grid-column: auto;
    }

    .production__copy {
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }
  }
</style>
