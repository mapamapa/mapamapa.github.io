---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = 'SATURNALIA — Celebración del Vino';
const description = 'Celebración dedicada al vino, la música y la cultura que reúne viñas de autor, destilerías, música en vivo y restaurantes pop-up.';

const heroVideo = '/img/work/saturnalia/hero-video.mp4';
const heroRepeat = 7;
const bottomVideo = '/img/work/saturnalia/bottom-video.mp4';

const gallery = {
  hero: '/img/work/saturnalia/hero.jpg',
  slide2: '/img/work/saturnalia/slide2.jpg',
  slide3: '/img/work/saturnalia/slide3.jpg',
  slide4: '/img/work/saturnalia/slide4.jpg',
  slide5: '/img/work/saturnalia/slide5.jpg',
};
---

<BaseLayout title={title} description={description} image={gallery.hero}>
  <section class="production container">
    <header class="production__header">
      <figure class="production__hero reveal">
        <div class="hero-video-strip">
          {Array.from({ length: heroRepeat }).map(() => (
            <video
              autoplay
              loop
              muted
              playsinline
              preload="none"
              data-src={heroVideo}
              poster={gallery.hero}
            />
          ))}
        </div>
      </figure>

      <div class="production__heading reveal reveal-delay-1">
        <h1>SATURNALIA</h1>
        <span class="production__subtitle">CELEBRACIÓN DEDICADA AL VINO, LA MÚSICA Y LA CULTURA</span>
      </div>
    </header>

    <section class="production__editorial" aria-labelledby="saturnalia-copy-title">
      <div class="production__copy reveal reveal-delay-2">
        <h2 id="saturnalia-copy-title" class="sr-only">Descripción del proyecto</h2>
        <p>
          Un encuentro que reúne a viñas de autor nacionales, destilerías, tiendas de vinilos, música
          en vivo y restaurantes pop-up.
        </p>
        <p>
          Con una propuesta curada y producida por MAPAMAPA, SATURNALIA busca conectar a quienes
          disfrutan de los mostos, los sonidos y los buenos encuentros, transformando la experiencia
          del vino en una verdadera fiesta cultural.
        </p>
        <p>
          Es un evento que celebra la diversidad, el oficio y el espíritu libre de quienes hacen del
          arte y el sabor una forma de vida.
        </p>
      </div>

      <div class="carousel reveal reveal-delay-2" id="sat-carousel">
        <div class="carousel__track" id="sat-track">
          {[gallery.slide2, gallery.slide3, gallery.slide4, gallery.slide5].map((src) => (
            <img
              src={src}
              alt=""
              width="1600"
              height="1067"
              loading="lazy"
              decoding="async"
            />
          ))}
        </div>
        <button class="carousel__arrow carousel__arrow--prev" id="sat-prev" aria-label="Anterior">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6" />
          </svg>
        </button>
        <button class="carousel__arrow carousel__arrow--next" id="sat-next" aria-label="Siguiente">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 18l6-6-6-6" />
          </svg>
        </button>
      </div>
    </section>

    <figure class="production__bottom-video reveal reveal-delay-3">
      <video
        loop
        muted
        playsinline
        preload="none"
        data-src={bottomVideo}
        poster={gallery.hero}
      />
    </figure>

    <p class="production__credits reveal reveal-delay-4">
      [Proyecto desarrollado con MAPACOMUN]
    </p>
  </section>
</BaseLayout>

<style>
  .production {
    padding-top: clamp(2.5rem, 4vw, 4rem);
    padding-bottom: var(--space-xl);
  }

  .production__header {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .production__hero {
    overflow: hidden;
    background: #060606;
    height: 540px;
  }

  .hero-video-strip {
    display: flex;
    width: 100%;
    height: 540px;
  }

  .hero-video-strip video {
    height: 100%;
    width: auto;
    flex-shrink: 0;
    object-fit: cover;
    display: block;
    clip-path: inset(0 25px);
    margin: 0 -60px;
  }

  .production__hero img,
  .production__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .production__heading {
    display: grid;
    gap: 0.4rem;
    width: 100%;
  }

  .production__heading h1 {
    font-size: clamp(2rem, 1.5rem + 2.8vw, 4rem);
    text-transform: uppercase;
    line-height: 0.95;
    color: #d7d7d7;
  }

  .production__subtitle {
    font-size: clamp(1.1rem, 0.9rem + 1vw, 1.8rem);
    color: #b1b1b1;
    font-weight: 400;
    text-transform: uppercase;
  }

  .production__editorial {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 0;
    align-items: stretch;
  }

  .production__copy {
    grid-column: span 6;
    display: grid;
    gap: 0.45rem;
    padding-right: var(--space-md);
    align-content: start;
  }

  .production__copy p {
    font-size: clamp(1rem, 0.92rem + 0.35vw, 1.18rem);
    line-height: 1.08;
    color: #c8c8c8;
    max-width: 598px;
  }

  .carousel {
    position: relative;
    grid-column: 7 / -1;
    overflow: hidden;
  }

  .carousel__track {
    display: flex;
    height: 430px;
  }

  .carousel__track img {
    width: 100%;
    height: 100%;
    flex-shrink: 0;
    object-fit: cover;
    display: block;
  }

  .carousel__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    cursor: pointer;
    transition: background-color var(--duration-fast), border-color var(--duration-fast);
    z-index: 2;
  }

  .carousel__arrow:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .carousel__arrow--prev { left: 8px; }
  .carousel__arrow--next { right: 8px; }

  .production__bottom-video {
    width: 100%;
    overflow: hidden;
  }

  .production__bottom-video video {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .production__credits {
    margin-top: var(--space-lg);
    font-size: 0.85rem;
    color: #888;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  @media (min-width: 900px) {
    .production__header {
      margin-bottom: var(--space-md);
    }

    .production__copy {
      padding-top: 0.25rem;
    }
  }

  @media (max-width: 899px) {
    .production__editorial {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .production__copy,
    .carousel {
      grid-column: auto;
    }

    .production__copy {
      padding-right: 0;
      margin-bottom: var(--space-sm);
    }
  }

  @media (max-width: 599px) {
    .production__hero {
      height: auto;
    }

    .hero-video-strip {
      height: auto;
    }

    .hero-video-strip video {
      width: 100%;
      height: auto;
      clip-path: none;
      margin: 0;
    }

    .hero-video-strip video:nth-child(n+2) {
      display: none;
    }

    .production__bottom-video video {
      max-height: 50vh;
    }
  }
</style>

<script>
  import { gsap } from '@/scripts/gsap';

  function initCarousel() {
    const track = document.getElementById('sat-track');
    const prevBtn = document.getElementById('sat-prev');
    const nextBtn = document.getElementById('sat-next');
    if (!track || !prevBtn || !nextBtn) return;

    const slides = track.querySelectorAll('img');
    const total = slides.length;
    let current = 0;
    let animating = false;

    function goTo(index: number) {
      if (animating) return;
      animating = true;
      current = (index + total) % total;
      gsap.to(track, {
        xPercent: -current * 100,
        duration: 0.6,
        ease: 'expo.out',
        onComplete: () => { animating = false; },
      });
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    const carousel = document.getElementById('sat-carousel');
    if (!carousel) return;
    let startX = 0;

    carousel.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
    }, { passive: true });

    carousel.addEventListener('touchend', (e) => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        goTo(diff > 0 ? current + 1 : current - 1);
      }
    }, { passive: true });
  }

  function lazyLoadVideos() {
    const videos = document.querySelectorAll<HTMLVideoElement>('video[data-src]');
    if (!videos.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const video = entry.target as HTMLVideoElement;
            video.src = video.dataset.src!;
            video.load();
            video.play();
            observer.unobserve(video);
          }
        });
      },
      { rootMargin: '200px' }
    );

    videos.forEach((video) => observer.observe(video));
  }

  document.addEventListener('astro:page-load', lazyLoadVideos);
  document.addEventListener('astro:page-load', initCarousel);
</script>
