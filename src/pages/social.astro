---
import BaseLayout from '@/layouts/BaseLayout.astro';

const images = [
  '01.png','02.jpg','03.jpg','04.jpg','05.jpg',
  '06.jpg','07.jpg','08.jpg','09.jpg','10.jpg',
  '11.jpg','12.jpg','13.jpg','14.jpg','15.jpg',
];

const cols = [
  [images[0], images[4], images[8], images[12]],
  [images[1], images[5], images[9], images[13]],
  [images[2], images[6], images[10], images[14]],
  [images[3], images[7], images[11]],
];

const quoteWords = [
  'La',
  'creatividad',
  'es',
  'el',
  'arma',
  'más',
  'importante,',
  'para',
  'hacer',
  'cambios',
  'importantes.',
];
---

<BaseLayout title="Social" description="Sigue a MAPA MAPA en redes sociales.">
  <!-- Image Board -->
  <section class="social-board container">
    <div class="board">
      {cols.map((col, ci) => (
        <div class="board__col">
          {col.map((img, ii) => (
            <div class={`board__item reveal reveal-delay-${(ci + ii) % 4 + 1}`}>
              <img
                src={`/social/${img}`}
                alt=""
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- Quote -->
  <section class="social-quote" data-scroll-quote>
    <div class="social-quote__inner container">
      <p
        class="social-quote__text"
        aria-label="La creatividad es el arma más importante, para hacer cambios importantes."
      >
        {quoteWords.map((word, index) => (
          <span
            class="social-quote__word"
            style={`--word-index:${index}`}
            data-quote-word
          >
            {word}
          </span>
        ))}
      </p>
    </div>
  </section>

  <!-- Colaboradores -->
  <section class="social-collab container">
    <div class="social-collab__group" data-scroll-group>
      <span class="social-collab__label">Partner</span>
      <div class="social-collab__logos">
        <img src="/social/logos/mcomun.png" alt="Mapa Común" class="social-collab__logo" style="--logo-delay:0s" />
        <img src="/social/logos/lupa.png" alt="Lupa" class="social-collab__logo" style="--logo-delay:0.15s" />
        <img src="/social/logos/simple.png" alt="Simple" class="social-collab__logo" style="--logo-delay:0.3s" />
      </div>
    </div>

    <div class="social-collab__group" data-scroll-group>
      <span class="social-collab__label">Amigos</span>
      <div class="social-collab__logos">
        <img src="/social/logos/indh.png" alt="IN(H)" class="social-collab__logo" style="--logo-delay:0s" />
        <img src="/social/logos/funktion.png" alt="Funktion-One" class="social-collab__logo social-collab__logo--lg" style="--logo-delay:0.15s" />
        <img src="/social/logos/grieta.png" alt="Grieta" class="social-collab__logo social-collab__logo--lg" style="--logo-delay:0.3s" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== IMAGE BOARD ===== */
  .social-board {
    position: relative;
    padding-top: calc(var(--space-sm) + 70px);
  }

  .social-board::before {
    content: '';
    display: block;
    position: sticky;
    top: 0;
    width: 100%;
    height: 220px;
    margin-bottom: -220px;
    background: linear-gradient(to bottom, var(--color-bg, #0a0a0a) 25%, transparent);
    pointer-events: none;
    z-index: 10;
  }

  .board {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    align-items: start;
  }

  .board__col {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .board__item {
    overflow: hidden;
  }

  .board__item img {
    width: 100%;
    height: auto;
    display: block;
    transition: filter 0.5s ease;
    filter: grayscale(30%);
  }

  .board__item:hover img {
    filter: grayscale(0%);
  }

  @media (max-width: 768px) {
    .board {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ===== QUOTE ===== */
  .social-quote {
    min-height: 160vh;
    position: relative;
  }

  .social-quote__inner {
    position: sticky;
    top: 25vh;
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .social-quote__text {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: 1.1;
    max-width: 700px;
    margin: 0 auto;
    color: #fff;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.18em 0.32em;
    perspective: 900px;
  }

  .social-quote__word {
    opacity: 0.14;
    transform: translate3d(0, 72px, 0);
    transition: opacity 0.35s ease, transform 0.6s var(--ease-out-expo);
    will-change: opacity, transform;
  }

  .social-quote__word--visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  /* ===== COLABORADORES ===== */
  .social-collab {
    padding-bottom: var(--space-xl);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .social-collab__group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s ease, transform 0.9s var(--ease-out-expo);
  }

  .social-collab__group--visible {
    opacity: 1;
    transform: translateY(0);
  }

  .social-collab__label {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: #fff;
  }

  .social-collab__logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xl);
  }

  .social-collab__logo {
    height: 65px;
    width: auto;
    object-fit: contain;
    filter: grayscale(100%) brightness(0.7);
    opacity: 0;
    transition: filter 0.4s ease, opacity 0.6s ease;
    transition-delay: var(--logo-delay, 0s);
  }

  .social-collab__group--visible .social-collab__logo {
    opacity: 1;
  }

  .social-collab__logo--lg {
    height: 118px;
  }

  .social-collab__logo:hover {
    filter: grayscale(0%) brightness(1);
  }

  @media (max-width: 480px) {
    .social-quote {
      min-height: 140vh;
    }

    .social-quote__inner {
      top: 20vh;
    }

    .social-collab__logos {
      gap: var(--space-lg);
    }

    .social-collab__logo {
      height: 47px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .social-quote {
      min-height: auto;
    }

    .social-quote__inner {
      position: static;
      min-height: auto;
      padding-top: calc(var(--space-3xl) + 100px);
      padding-bottom: var(--space-3xl);
    }

    .social-quote__word,
    .social-collab__group {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  let socialScrollCleanup: (() => void) | null = null;

  function initSocialScrollReveal() {
    if (socialScrollCleanup) {
      socialScrollCleanup();
      socialScrollCleanup = null;
    }

    const quoteSection = document.querySelector<HTMLElement>('[data-scroll-quote]');
    const quoteWords = Array.from(document.querySelectorAll<HTMLElement>('[data-quote-word]'));
    const collabGroups = Array.from(document.querySelectorAll<HTMLElement>('[data-scroll-group]'));

    if (!quoteSection || !quoteWords.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      quoteWords.forEach((w) => w.classList.add('social-quote__word--visible'));
      collabGroups.forEach((g) => g.classList.add('social-collab__group--visible'));
      return;
    }

    function update() {
      const vh = window.innerHeight;
      const sectionRect = quoteSection!.getBoundingClientRect();

      const scrollableDistance = sectionRect.height - vh;
      const scrolled = -sectionRect.top;
      const progress = Math.min(Math.max(scrolled / scrollableDistance, 0), 1);

      const count = quoteWords.length;

      quoteWords.forEach((word, i) => {
        const wordStart = i / count;
        const wordEnd = (i + 1) / count;
        const local = Math.min(Math.max((progress - wordStart) / (wordEnd - wordStart), 0), 1);

        word.style.opacity = `${0.1 + local * 0.9}`;
        word.style.transform = `translate3d(0, ${(1 - local) * 60}px, 0)`;
      });
    }

    let ticking = false;

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        update();
        ticking = false;
      });
    }

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);

    const groupObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('social-collab__group--visible');
            groupObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05 }
    );
    collabGroups.forEach((g) => groupObserver.observe(g));

    socialScrollCleanup = () => {
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('resize', onScroll);
      groupObserver.disconnect();
    };
  }

  initSocialScrollReveal();
  document.addEventListener('astro:after-swap', initSocialScrollReveal);
</script>
