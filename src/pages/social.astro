---
import BaseLayout from '@/layouts/BaseLayout.astro';

const images = [
  '01.png','02.jpg','03.jpg','04.jpg','05.jpg',
  '06.jpg','07.jpg','08.jpg','09.jpg','10.jpg',
  '11.jpg','12.jpg','13.jpg','14.jpg','15.jpg',
];

const cols = [
  [images[0], images[4], images[8], images[12]],
  [images[1], images[5], images[9], images[13]],
  [images[2], images[6], images[10], images[14]],
  [images[3], images[7], images[11]],
];
---

<BaseLayout title="Social" description="Sigue a MAPA MAPA en redes sociales.">
  <!-- Image Board -->
  <section class="social-board container">
    <div class="board">
      {cols.map((col, ci) => (
        <div class="board__col">
          {col.map((img, ii) => (
            <div class={`board__item reveal reveal-delay-${(ci + ii) % 4 + 1}`}>
              <img
                src={`/social/${img}`}
                alt=""
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- Quote -->
  <section class="social-quote reveal">
    <div class="social-quote__inner container">
      <p class="social-quote__text">
        La creatividad es el arma más importante, para hacer cambios importantes
      </p>
    </div>
  </section>

  <!-- Colaboradores -->
  <section class="social-collab container">
    <div class="social-collab__group reveal">
      <span class="social-collab__label">Partner</span>
      <div class="social-collab__logos">
        <img src="/social/logos/mcomun.png" alt="Mapa Común" class="social-collab__logo" />
        <img src="/social/logos/lupa.png" alt="Lupa" class="social-collab__logo" />
        <img src="/social/logos/simple.png" alt="Simple" class="social-collab__logo" />
      </div>
    </div>

    <div class="social-collab__group reveal reveal-delay-1">
      <span class="social-collab__label">Amigos</span>
      <div class="social-collab__logos">
        <img src="/social/logos/indh.png" alt="IN(H)" class="social-collab__logo" />
        <img src="/social/logos/grieta.png" alt="Grieta" class="social-collab__logo social-collab__logo--lg" />
        <img src="/social/logos/funktion.png" alt="Funktion-One" class="social-collab__logo social-collab__logo--lg" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== IMAGE BOARD ===== */
  .social-board {
    padding-top: calc(var(--space-sm) + 70px);
  }

  .board {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    align-items: start;
  }

  .board__col {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .board__item {
    overflow: hidden;
  }

  .board__item img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s var(--ease-out-expo), filter 0.5s ease;
    filter: grayscale(30%);
  }

  .board__item:hover img {
    transform: scale(1.04);
    filter: grayscale(0%);
  }

  @media (max-width: 768px) {
    .board {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ===== QUOTE ===== */
  .social-quote {
    padding-top: calc(var(--space-3xl) + 100px);
    padding-bottom: var(--space-3xl);
  }

  .social-quote__inner {
    text-align: center;
  }

  .social-quote__text {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: 1.1;
    max-width: 700px;
    margin: 0 auto;
    color: #fff;
  }

  /* ===== COLABORADORES ===== */
  .social-collab {
    padding-bottom: var(--space-xl);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .social-collab__group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .social-collab__label {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: #fff;
  }

  .social-collab__logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-xl);
  }

  .social-collab__logo {
    height: 50px;
    width: auto;
    object-fit: contain;
    filter: grayscale(100%) brightness(0.7);
    transition: filter 0.4s ease;
  }

  .social-collab__logo--lg {
    height: 70px;
  }

  .social-collab__logo:hover {
    filter: grayscale(0%) brightness(1);
  }

  @media (max-width: 480px) {
    .social-collab__logos {
      gap: var(--space-lg);
    }

    .social-collab__logo {
      height: 36px;
    }
  }
</style>
