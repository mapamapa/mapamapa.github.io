---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '../../public/data/site.json';

const socials = site.social;
---

<BaseLayout title="Social" description="Sigue a MAPA MAPA en redes sociales.">
  <section class="social-hero">
    <div class="social-hero__inner container">
      <span class="social-hero__label reveal">Redes</span>
      <h1 class="social-hero__title reveal reveal-delay-1">Social</h1>
      <p class="social-hero__desc reveal reveal-delay-2">
        Síguenos para ver proyectos en desarrollo, procesos creativos
        y todo lo que nos inspira.
      </p>
    </div>
  </section>

  <section class="social-links container">
    <div class="social-links__list">
      {socials.map((social, i) => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          class={`social-card reveal reveal-delay-${i + 1}`}
        >
          <div class="social-card__header">
            <h2 class="social-card__name">{social.name}</h2>
            <svg class="social-card__arrow" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </div>
          <span class="social-card__handle">{social.handle}</span>
          <p class="social-card__desc">{social.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .social-hero {
    padding-top: calc(var(--space-3xl) + 80px);
    padding-bottom: var(--space-2xl);
  }

  .social-hero__label {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .social-hero__title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-xs);
  }

  .social-hero__desc {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    max-width: 500px;
    line-height: 1.15;
  }

  /* Cards */
  .social-links__list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background-color: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .social-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md);
    background-color: var(--color-bg);
    transition: background-color var(--duration-normal) var(--ease-out-expo);
  }

  .social-card:hover {
    background-color: var(--color-bg-elevated);
  }

  .social-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .social-card__name {
    font-size: var(--text-3xl);
    font-weight: 700;
    transition: color var(--duration-fast);
  }

  .social-card:hover .social-card__name {
    color: var(--color-hover);
  }

  .social-card__arrow {
    transition: transform var(--duration-fast) var(--ease-out-expo);
    color: var(--color-text-muted);
  }

  .social-card:hover .social-card__arrow {
    transform: translate(4px, -4px);
    color: var(--color-hover);
  }

  .social-card__handle {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--color-hover);
  }

  .social-card__desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    max-width: 400px;
  }
</style>
