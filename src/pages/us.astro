---
import BaseLayout from '@/layouts/BaseLayout.astro';
import site from '../../public/data/site.json';

const { about } = site;
---

<BaseLayout title="Us" description="Conoce a MAPA MAPA — Gestión y producción cultural.">
  <section class="us-hero">
    <div class="us-hero__video">
      <video autoplay loop muted playsinline data-wait-video>
        <source src="/img/vid-us.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="us-hero__text container">
      <span class="us-hero__label reveal">{about.title}</span>
      <h1 class="us-hero__title reveal reveal-delay-1">
        {about.subtitle}
      </h1>
    </div>
  </section>

  <section class="us-about container">
    <div class="us-about__grid">
      <div class="us-about__col reveal">
        <p class="us-about__text us-about__text--large">{about.body}</p>
      </div>
      <div class="us-about__col reveal reveal-delay-2">
        <p class="us-about__text">{about.body2}</p>
      </div>
    </div>
  </section>

  <section class="us-origin container">
    <p class="us-origin__text reveal">{about.origin}</p>
  </section>

  <section class="us-team container">
    <div class="us-team__grid">
      <article class="us-team__card us-team__card--right reveal">
        <h2 class="us-team__name">Pablo<br />Gutiérrez</h2>
        <div class="us-team__photo">
          <img src="/img-opt/us/pablo.webp" alt="Pablo Gutiérrez" width="400" height="400" loading="lazy" decoding="async" />
        </div>
      </article>
      <article class="us-team__card us-team__card--left reveal reveal-delay-1">
        <div class="us-team__photo">
          <img src="/img-opt/us/matias.webp" alt="Matías Gutiérrez" width="400" height="400" loading="lazy" decoding="async" />
        </div>
        <h2 class="us-team__name">Matías<br />Gutiérrez</h2>
      </article>
      <article class="us-team__card us-team__card--right reveal reveal-delay-2">
        <h2 class="us-team__name">Carolina<br />Caimanque</h2>
        <div class="us-team__photo">
          <img src="/img-opt/us/carolina.webp" alt="Carolina Caimanque" width="400" height="400" loading="lazy" decoding="async" />
        </div>
      </article>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .us-hero {
    padding-top: 60px;
  }

  .us-hero__video {
    width: 100%;
    display: flex;
    justify-content: center;
    overflow: hidden;
  }

  .us-hero__video video {
    width: 100%;
    max-height: 70vh;
    object-fit: cover;
  }

  .us-hero__text {
    padding-top: var(--space-sm);
    padding-bottom: var(--space-md);
  }

  .us-hero__label {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 900;
    line-height: 0.85;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #ffffff;
    margin-bottom: var(--space-sm);
  }

  .us-hero__title {
    font-size: var(--text-lg);
    color: #ffffff;
    max-width: 700px;
    font-weight: 400;
  }

  .us-hero__accent {
    color: var(--color-accent);
    font-style: italic;
  }

  /* About */
  .us-about {
    padding-top: var(--space-sm);
    padding-bottom: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .us-about__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .us-about__grid {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .us-about__col {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .us-about__text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.25;
  }

  .us-about__text--large {
    font-size: var(--text-xl);
    color: var(--color-text);
    line-height: 1.15;
  }

  /* Origin */
  .us-origin {
    padding-top: var(--space-sm);
    padding-bottom: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .us-origin__text {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.35;
    max-width: 720px;
  }

  /* Team */
  .us-team {
    padding-top: var(--space-md);
    padding-bottom: var(--space-md);
  }

  .us-team__grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .us-team__card {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    outline: 1px solid transparent;
    padding: var(--space-sm);
    transition: outline-color 0.4s ease;
  }

  .us-team__card:hover {
    outline-color: #fff;
  }

  .us-team__card--right {
    justify-content: flex-end;
  }

  .us-team__card--left {
    justify-content: flex-start;
  }

  .us-team__name {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 900;
    line-height: 0.95;
    color: #fff;
    flex-shrink: 0;
  }

  .us-team__photo {
    width: clamp(150px, 25vw, 300px);
    aspect-ratio: 1;
    overflow: hidden;
    flex-shrink: 0;
  }

  .us-team__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1);
    transition: filter 0.4s ease;
  }

  .us-team__card:hover .us-team__photo img {
    filter: grayscale(0);
  }

  @media (max-width: 480px) {
    .us-team__card {
      flex-direction: column;
      text-align: center;
    }

    .us-team__card--right,
    .us-team__card--left {
      justify-content: center;
    }

    .us-team__name {
      font-size: var(--text-2xl);
      order: 2;
    }

    .us-team__photo {
      order: 1;
    }
  }
</style>
