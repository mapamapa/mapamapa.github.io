---
import BaseLayout from '@/layouts/BaseLayout.astro';

const images = [
  'bachelet.webp', 'sneak.webp', 'eclipse.webp', 'mariana.webp', 'cena.webp', 'food.webp', 'irl.webp',
  'cnc.webp', 'jaar.webp', 'dance.webp', 'expor.webp', 'banksy.webp', 'moneda.webp',
  'saturnalia.webp', 'murmullo.webp', 'wallmart.webp', 'nacional.webp', 'dj.webp',
  'dance2.webp', 'exp.webp', 'nicole.webp', 'lagos.webp', 'susurro.webp', 'mortal.webp', 'arte.webp',
];

const rows = [
  images.slice(0, 7),
  images.slice(7, 13),
  images.slice(13, 19),
  images.slice(19),
];
---

<BaseLayout title="Work" description="Proyectos de MAPA MAPA — Gestión y producción cultural.">
  <section class="work">
    {rows.map((row, i) => (
      <div class={`work__row work__row--${i % 2 === 0 ? 'left' : 'right'} work__row--speed-${i}`}>
        <div class="work__track">
          {row.map((img) => (
            <div class="work__item">
              <img src={`/img-opt/work/${img}`} alt="" width="400" height="400" loading="lazy" decoding="async" crossorigin="anonymous" />
            </div>
          ))}
          {row.map((img) => (
            <div class="work__item" aria-hidden="true">
              <img src={`/img-opt/work/${img}`} alt="" width="400" height="400" loading="lazy" decoding="async" crossorigin="anonymous" />
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>

<style>
  .work {
    padding-top: 60px;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    overflow: hidden;
  }

  .work__row {
    overflow: hidden;
  }

  .work__track {
    display: flex;
    gap: var(--space-xs);
    width: max-content;
    will-change: transform;
  }

  .work__row--left .work__track {
    animation: scroll-left var(--row-duration, 40s) linear infinite;
  }

  .work__row--right .work__track {
    animation: scroll-right var(--row-duration, 40s) linear infinite;
  }

  .work__row--speed-0 { --row-duration: 35s; }
  .work__row--speed-1 { --row-duration: 45s; }
  .work__row--speed-2 { --row-duration: 38s; }
  .work__row--speed-3 { --row-duration: 50s; }

  .work__item {
    flex-shrink: 0;
    width: clamp(150px, 22vw, 300px);
    aspect-ratio: 1;
    overflow: hidden;
    position: relative;
    cursor: pointer;
  }

  .work__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease;
  }

  .work__item--dissolving img {
    opacity: 0 !important;
  }

  @keyframes scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes scroll-right {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .work__track {
      animation: none !important;
    }
  }
</style>

<script>
  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    r: number;
    g: number;
    b: number;
    size: number;
    life: number;
  }

  function dissolve(item: HTMLElement) {
    if (item.classList.contains('work__item--dissolving')) return;

    const img = item.querySelector('img') as HTMLImageElement;
    if (!img) return;

    const w = item.offsetWidth;
    const h = item.offsetHeight;
    const PAD = 200;
    const cw = w + PAD * 2;
    const ch = h + PAD * 2;

    const rect = item.getBoundingClientRect();

    let imageData: Uint8ClampedArray | null = null;
    try {
      const source = document.createElement('canvas');
      source.width = w;
      source.height = h;
      const sCtx = source.getContext('2d')!;
      sCtx.drawImage(img, 0, 0, w, h);
      imageData = sCtx.getImageData(0, 0, w, h).data;
    } catch {
      imageData = null;
    }

    const canvas = document.createElement('canvas');
    canvas.width = cw;
    canvas.height = ch;
    canvas.style.cssText = `position:fixed;left:${rect.left - PAD}px;top:${rect.top - PAD}px;width:${cw}px;height:${ch}px;pointer-events:none;z-index:9999;`;
    document.body.appendChild(canvas);
    const ctx = canvas.getContext('2d')!;

    const GRID = 3;
    const particles: Particle[] = [];

    for (let y = 0; y < h; y += GRID) {
      for (let x = 0; x < w; x += GRID) {
        let r = 180, g = 180, b = 180;

        if (imageData) {
          const i = (y * w + x) * 4;
          if (imageData[i + 3] < 30) continue;
          r = imageData[i];
          g = imageData[i + 1];
          b = imageData[i + 2];
        }

        const angle = Math.random() * Math.PI * 2;
        const speed = 1 + Math.random() * 4;

        particles.push({
          x: x + PAD,
          y: y + PAD,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed - 2,
          r, g, b,
          size: GRID * (0.5 + Math.random() * 0.7),
          life: 0.5 + Math.random() * 0.5,
        });
      }
    }

    item.classList.add('work__item--dissolving');

    const DURATION = 1400;
    const start = performance.now();

    function frame(now: number) {
      const elapsed = now - start;
      const t = Math.min(elapsed / DURATION, 1);

      ctx.clearRect(0, 0, cw, ch);

      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.06;
        p.vx *= 0.98;
        const alpha = p.life * (1 - t * t);

        if (alpha <= 0.01) continue;

        ctx.globalAlpha = alpha;
        ctx.fillStyle = `rgb(${p.r},${p.g},${p.b})`;
        ctx.fillRect(p.x, p.y, p.size, p.size);
      }

      if (t < 1) {
        requestAnimationFrame(frame);
      } else {
        canvas.remove();
        item.classList.remove('work__item--dissolving');
      }
    }

    requestAnimationFrame(frame);
  }

  function initDissolve() {
    document.querySelectorAll<HTMLElement>('.work__item').forEach((item) => {
      item.addEventListener('click', () => dissolve(item));
    });
  }

  initDissolve();
  document.addEventListener('astro:after-swap', initDissolve);
</script>
